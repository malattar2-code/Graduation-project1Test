# ==============================
#  مجلدات التبعيات (الأكبر حجماً)
# ==============================
node_modules/
bower_components/

# ==============================
#  ملفات البيئة والخصوصية
# ==============================
.env
.env.local
.env.*.local

# ==============================
#  مجلدات رفع الملفات والوسائط (المسؤول الأول عن الحجم الكبير)
# ==============================
uploads/
media/
public/uploads/
public/images/
videos/
screenshots/
temp/

# ==============================
#  ملفات مضغوطة وثنائية (لا ترفعها)
# ==============================
*.zip
*.rar
*.7z
*.tar.gz
*.mp4
*.avi
*.mov
*.mkv

# ==============================
#  مخرجات البناء (Build)
# ==============================
dist/
build/
out/

# ==============================
#  ملفات السجلات (Logs)
# ==============================
logs/
*.log

# Sensitive files and Backups
*.sql
*.json
!package.json
!package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================
#  ملفات نظام التشغيل
# ==============================
.DS_Store
Thumbs.db
*.tmp

# ==============================
#  ملفات بيئة التطوير (IDE)
# ==============================
.vscode/
.idea/
*.swp
*.swo

# ==============================
#  ملفات قواعد البيانات المحلية
# ==============================
*.sqlite
*.db
*.sql

# ==============================
#  ملفات الحزم المؤقتة
# ==============================
package-lock.json
yarn.lock
services/cities5000.txt

# استثناء كافة مجلدات الصور والوسائط في المشروع
public/assets/image/
views+frontendjs+css/css/
**/*.gif
**/*.jpg
**/*.jpeg
**/*.png
**/*.ico
**/*.svg
**/*.mp4