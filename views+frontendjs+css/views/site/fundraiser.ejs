  <!-- Jquery -->
  <script>
    // Get fundraiser ID from URL for real-time updates
    window.fundraiserId = '<%= fundraiserData.fundraiserId %>';
    window.initialData = {
        collectedAmount: '<%= fundraiserData.collectedAmount %>',
        targetAmount: '<%= fundraiserData.targetAmount %>',
        progress: '<%= fundraiserData.progress %>',
    };
  </script>
  <script>
    // بيانات المستخدم (يجب استبدالها بالبيانات الفعلية)
    // يمكن أن يكون: "donor", "requester", أو غير معرّف
    const userType = sessionStorage.getItem("userType");
    const buttonsContainer = document.getElementById('buttons-container');

    if (!userType || userType === "donor" || userType === "superadmin") {
        // عرض زر التبرع إذا لم يكن UserType معرّف أو إذا كان donor
        buttonsContainer.innerHTML = `<a id="donateButton" class="donate-btn btn-website" data-i18n="fundraiserDonateBtnTgt">Donate</a>` 
    } else if (userType === "requester") {
        // عرض زر إضافة صندوق إذا كان requester
        buttonsContainer.innerHTML = '<p class="donate-btn btn-website" data-i18n="fundraiserDonateBtnIndigentTgt">Indigent Does Not Donate</p>';
    }
  </script>
  <script src="/assets/js/jquery.js"></script>
  <!-- Owl Carousel js -->
  <script src="/assets/js/owl.carousel.min.js"></script>
  <!-- مكتبات i18next من CDN -->
  <script src="/assets/libs/i18next.min.js"></script>
  <script src="/assets/libs/i18nextHttpBackend.js"></script>
  <script src="/assets/libs/i18nextBrowserLanguageDetector.js"></script>
  <!-- Custom my js -->
  <div id="fundraiser-data" 
    data-fundraiser-id="<%= fundraiserData.fundraiserId %>"
    style="display: none;">
  </div>
  <script src="/assets/js/fundraiser.js"></script>
  <!-- FontAwesome Icon-->
  <!-- <script src="https://kit.fontawesome.com/6fccdcc8fe.js" crossorigin="anonymous"></script> -->
  <!-- نافذة التبرع -->
  <div id="donationModal" class="modal">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h2 data-i18n="donateNow">تبرع الآن</h2>
  
      <form id="donationForm">
        <input type="hidden" id="fundraiserId">
        <input type="hidden" id="fundraiserTitle">
        <input type="hidden" id="targetAmount">
  
        <div class="form-group">
          <label for="donorName" data-i18n="donorName">اسم المتبرع:</label>
          <input type="text" id="donorName" required>
        </div>
  
        <div class="form-group">
          <label for="donationAmount" data-i18n="donationAmount">مبلغ التبرع ($):</label>
          <input type="number" id="donationAmount" min="1" step="0.01" required>
          <small data-i18n="minDonation">الحد الأدنى للتبرع: $1</small>
        </div>
  
        <div class="form-buttons">
          <button type="button" id="cancelBtn" data-i18n="cancel">إلغاء</button>
          <button type="submit" id="continueBtn" data-i18n="continueToPayment">متابعة إلى الدفع</button>
        </div>
      </form>
    </div>
  </div>
  
  <!-- نافذة خيارات الدفع -->
  <div id="paymentMethodModal" class="modal">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h2 data-i18n="choosePaymentMethod">اختر طريقة الدفع</h2>
  
      <div class="payment-options">
        <label>
          <input type="radio" name="paymentMethod" value="card" checked>
          <span class="payment-method-icon">💳</span>
          <span data-i18n="creditDebitCard">بطاقة ائتمان/خصم</span>
        </label>
        <label>
          <input type="radio" name="paymentMethod" value="wallet">
          <span class="payment-method-icon">📱</span>
          <span data-i18n="eWallet">محفظة إلكترونية</span>
        </label>
        <label>
          <input type="radio" name="paymentMethod" value="bank">
          <span class="payment-method-icon">🏦</span>
          <span data-i18n="bankTransfer">تحويل بنكي</span>
        </label>
      </div>
  
      <!-- حاوية بطاقات الائتمان -->
      <div id="cardPaymentFields" class="payment-fields">
        <h3 data-i18n="cardDetails">تفاصيل البطاقة</h3>
  
        <div class="form-group">
          <label for="cardholderName" data-i18n="cardholderName">اسم حامل البطاقة:</label>
          <input type="text" id="cardholderName" placeholder="الاسم كما هو مدون على البطاقة">
        </div>
  
        <div class="form-group">
          <label for="card-element" data-i18n="cardNumber">رقم البطاقة:</label>
          <div id="card-element" class="StripeElement">
            <!-- سيتم إدراج Stripe Elements هنا -->
          </div>
          <div class="card-icons">
            <span class="card-icon">💳</span>
            <span class="card-icon">🔒</span>
          </div>
        </div>
  
        <div class="form-row">
          <div class="form-group">
            <label for="card-expiry" data-i18n="expiryDate">تاريخ الانتهاء:</label>
            <div id="card-expiry" class="StripeElement">
              <!-- سيتم إدراج Stripe Elements هنا -->
            </div>
          </div>
  
          <div class="form-group">
            <label for="card-cvc" data-i18n="cvv">CVV:</label>
            <div id="card-cvc" class="StripeElement">
              <!-- سيتم إدراج Stripe Elements هنا -->
            </div>
            <div class="cvv-hint" data-i18n="cvvHint">الرقم المكون من 3 أو 4 أرقام على ظهر البطاقة</div>
          </div>
        </div>
        <div id="card-errors" class="error-message" role="alert" style="display: none;"></div>
      </div>
  
      <!-- حاوية المحفظة الإلكترونية -->
      <div id="walletPaymentFields" class="payment-fields" style="display: none;">
        <h3 data-i18n="eWalletPayment">الدفع عبر المحفظة الإلكترونية</h3>
        
        <div class="wallet-options">
          <div class="wallet-option" data-wallet-type="zain_cash">
            <div class="wallet-icon">📱</div>
            <div class="wallet-info">
              <div class="wallet-name">Zain Cash</div>
              <div class="wallet-description">الدفع عبر تطبيق Zain Cash</div>
            </div>
          </div>
          
          <div class="wallet-option" data-wallet-type="asia_hawala">
            <div class="wallet-icon">💸</div>
            <div class="wallet-info">
              <div class="wallet-name">Asia Hawala</div>
              <div class="wallet-description">الدفع عبر Asia Hawala</div>
            </div>
          </div>
          
          <div class="wallet-option" data-wallet-type="other">
            <div class="wallet-icon">📲</div>
            <div class="wallet-info">
              <div class="wallet-name">محفظة أخرى</div>
              <div class="wallet-description">اختر هذه الخيار لمحفظة أخرى</div>
            </div>
          </div>
        </div>
        
        <div class="form-group" id="walletPhoneGroup" style="display: none;">
          <label for="walletPhone" data-i18n="walletPhone">رقم الهاتف المرتبط بالمحفظة:</label>
          <input type="tel" id="walletPhone" placeholder="07XXXXXXXX">
        </div>
        
        <div class="form-group" id="customWalletGroup" style="display: none;">
          <label for="customWalletName" data-i18n="walletName">اسم المحفظة:</label>
          <input type="text" id="customWalletName" placeholder="أدخل اسم المحفظة">
        </div>
      </div>
  
      <!-- حاوية التحويل البنكي -->
      <div id="bankPaymentFields" class="payment-fields" style="display: none;">
        <h3 data-i18n="bankTransfer">تحويل بنكي</h3>
        
        <div class="bank-info">
          <div class="bank-detail">
            <span data-i18n="bankName">اسم البنك:</span>
            <span>البنك المركزي</span>
          </div>
          <div class="bank-detail">
            <span data-i18n="accountName">اسم الحساب:</span>
            <span>مشاريع الخير</span>
          </div>
          <div class="bank-detail">
            <span data-i18n="accountNumber">رقم الحساب:</span>
            <span>1234567890</span>
          </div>
          <div class="bank-detail">
            <span data-i18n="iban">IBAN:</span>
            <span>SA03 8000 0000 6080 1016 7519</span>
          </div>
        </div>
        
        <div class="form-group">
          <label for="bankRef" data-i18n="transferReference">رقم المرجع:</label>
          <input type="text" id="bankRef" readonly value="DON-{{timestamp}}">
          <small data-i18n="transferReferenceHint">يرجى استخدام هذا الرقم كمرجع عند التحويل</small>
        </div>
        
        <div class="form-group">
          <label for="transferProof" data-i18n="transferProof">إثبات التحويل (اختياري):</label>
          <input type="file" id="transferProof" accept="image/*,.pdf">
          <small data-i18n="transferProofHint">يمكنك رفع صورة من إيصال التحويل</small>
        </div>
      </div>
  
      <div class="donation-summary">
        <h3 data-i18n="donationSummary">ملخص التبرع</h3>
        <p data-i18n="donor">المتبرع: <span id="summaryDonorName"></span></p>
        <p data-i18n="amount">المبلغ: $<span id="summaryAmount"></span></p>
        <p data-i18n="campaign">الحملة: <span id="summaryCampaign"></span></p>
        <p data-i18n="paymentMethod">طريقة الدفع: <span id="summaryPaymentMethod"></span></p>
      </div>
  
      <div class="security-notice">
        <div class="security-icon">🔒</div>
        <span data-i18n="securityNotice">بياناتك محمية ومشفرة بأعلى معايير الأمان</span>
      </div>
  
      <div class="form-buttons">
        <button type="button" id="backBtn" data-i18n="back">رجوع</button>
        <button type="button" id="proceedPaymentBtn" data-i18n="completePayment">إتمام الدفع</button>
      </div>
    </div>
  </div>
  
  <!-- نافذة التحميل -->
  <div id="loadingModal" class="modal">
    <div class="modal-content loading-content">
      <div class="spinner"></div>
      <p id="loadingMessage" data-i18n="processingPayment">جاري معالجة الدفع...</p>
    </div>
  </div>

  <!-- نافذة النجاح -->
  <div id="successModal" class="modal">
    <div class="modal-content loading-content">
      <div style="color: #4CAF50; font-size: 48px; margin-bottom: 20px;">✓</div>
      <h3 data-i18n="paymentSuccess">تم الدفع بنجاح!</h3>
      <p id="successMessage"></p>
      <div class="form-buttons">
        <button type="button" id="successCloseBtn" data-i18n="close">إغلاق</button>
      </div>
    </div>
  </div>
  <script>
    const STRIPE_PUBLIC_KEY = 'pk_test_51SBtChDAEAM6yuRiFQzCs0fEXOKoHZ10lCV3PJGxPb1TTYOkpL0gFmE3IEnqmEC3bjNrGehL3n9M3bZdjop3nRJV00AgWo6i4B';

    let currentDonationData = {};
    let currentUser = {};
    let stripe = null;
    let elements = null;
    let cardNumber = null;
    let cardExpiry = null;
    let cardCvc = null;
    let cardElementsMounted = false;
    let mountRetryTimer = null;
    let selectedWalletType = null;

    // ---------- Get fundraiser data from template ----------
    function getFundraiserData() {
      // Get fundraiser ID from the template variable
      const fundraiserId = '<%= fundraiserData.fundraiserId %>';
      
      // Get fundraiser title from the template
      const fundraiserTitle = '<%= fundraiserData.title %>';
      
      // Get target amount from the template
      const targetAmount = <%= fundraiserData.targetAmount %>;
      
      // Get collected amount from the template
      const collectedAmount = <%= fundraiserData.collectedAmount %>;
      
      return {
        fundraiserId,
        fundraiserTitle,
        targetAmount,
        collectedAmount
      };
    }

    // ---------- Get fundraiser ID from URL ----------
    function getFundraiserIdFromURL() {
      const path = window.location.pathname;
      const matches = path.match(/\/fundraiser\/([^\/]+)/);
      return matches ? matches[1] : null;
    }

    // ---------- Initialize Stripe ----------
    function initializeStripe() {
      if (!window.Stripe) {
        console.error('Stripe.js not loaded');
        return;
      }
      stripe = Stripe(STRIPE_PUBLIC_KEY);
      elements = stripe.elements();

      const style = {
        base: {
          fontSize: '16px',
          color: '#32325d',
          fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
          '::placeholder': { color: '#aab7c4' }
        },
        invalid: {
          color: '#fa755a',
          iconColor: '#fa755a'
        }
      };

      cardNumber = elements.create('cardNumber', { style, placeholder: '4242 4242 4242 4242' });
      cardExpiry = elements.create('cardExpiry', { style });
      cardCvc = elements.create('cardCvc', { style });

      const cardErrorEl = () => document.getElementById('card-errors');
      cardNumber.on('change', e => { 
        if (cardErrorEl()) {
          cardErrorEl().textContent = e.error ? e.error.message : '';
          cardErrorEl().style.display = e.error ? 'block' : 'none';
        }
      });
      cardExpiry.on('change', e => { 
        if (cardErrorEl()) {
          cardErrorEl().textContent = e.error ? e.error.message : '';
          cardErrorEl().style.display = e.error ? 'block' : 'none';
        }
      });
      cardCvc.on('change', e => { 
        if (cardErrorEl()) {
          cardErrorEl().textContent = e.error ? e.error.message : '';
          cardErrorEl().style.display = e.error ? 'block' : 'none';
        }
      });
    }

    // ---------- Mount/unmount helpers ----------
    function mountCardElements(retryInterval = 150) {
      if (cardElementsMounted) return;
      const numContainer = document.getElementById('card-element');
      const expContainer = document.getElementById('card-expiry');
      const cvcContainer = document.getElementById('card-cvc');

      if (!numContainer || !expContainer || !cvcContainer) {
        if (mountRetryTimer) clearTimeout(mountRetryTimer);
        mountRetryTimer = setTimeout(() => mountCardElements(retryInterval), retryInterval);
        return;
      }

      try {
        cardNumber.mount('#card-element');
        cardExpiry.mount('#card-expiry');
        cardCvc.mount('#card-cvc');
        cardElementsMounted = true;
        if (mountRetryTimer) { clearTimeout(mountRetryTimer); mountRetryTimer = null; }
        console.log('✅ Stripe Elements mounted');
      } catch (err) {
        console.warn('Retry mounting Stripe Elements', err);
        if (mountRetryTimer) clearTimeout(mountRetryTimer);
        mountRetryTimer = setTimeout(() => mountCardElements(retryInterval), retryInterval);
      }
    }

    function unmountCardElements() {
      try {
        if (cardElementsMounted) {
          cardNumber.unmount();
          cardExpiry.unmount();
          cardCvc.unmount();
          cardElementsMounted = false;
          console.log('🧹 Stripe Elements unmounted');
        }
      } catch (err) {
        console.warn('Error during unmount:', err);
      }
    }

    // ---------- Fetch current user ----------
    async function fetchCurrentUser() {
      try {
        const res = await fetch('/api/payments/me', { credentials: 'include' });
        if (!res.ok) throw new Error('فشل في جلب بيانات المستخدم');
        const data = await res.json();
        currentUser = { uid: data.uid || null, name: data.name || 'مستخدم مجهول', email: data.email || null };
        const donorInput = document.getElementById('donorName');
        if (donorInput) donorInput.value = currentUser.name;
      } catch (err) {
        console.error('fetchCurrentUser error:', err);
        currentUser = { uid: null, name: 'مستخدم مجهول', email: null };
      }
    }

    // ---------- Open modal ----------
    function openDonationModal() {
      const fundraiserData = getFundraiserData();
      
      // Fallback: try to get fundraiser ID from URL if not available in template
      let fundraiserId = fundraiserData.fundraiserId;
      if (!fundraiserId) {
        fundraiserId = getFundraiserIdFromURL();
      }

      if (!fundraiserId) {
        console.error('Fundraiser ID not found');
        showErrorMessage('تعذر العثور على بيانات الحملة');
        return;
      }

      currentDonationData = {
        fundraiserId,
        fundraiserTitle: fundraiserData.fundraiserTitle,
        donorName: currentUser.name || 'مستخدم مجهول',
        donorId: currentUser.uid || null,
        targetAmount: fundraiserData.targetAmount
      };

      // Set form values
      document.getElementById('fundraiserId').value = fundraiserId;
      document.getElementById('fundraiserTitle').value = fundraiserData.fundraiserTitle;
      document.getElementById('targetAmount').value = fundraiserData.targetAmount;
      document.getElementById('donorName').value = currentUser.name || 'مستخدم مجهول';

      // إنشاء رقم مرجعي للتحويل البنكي
      const timestamp = Date.now();
      document.getElementById('bankRef').value = `DON-${timestamp}`;

      document.getElementById('donationModal').style.display = 'block';
      setTimeout(() => mountCardElements(), 200);
    }

    // ---------- Create invoice ----------
    async function createInvoice(donationData) {
      const selectedMethod = donationData.paymentMethod;
      let paymentDetails = {
        donorName: donationData.donorName,
        donorEmail: currentUser.email || null
      };

      // إضافة تفاصيل إضافية بناءً على طريقة الدفع
      if (selectedMethod === 'wallet') {
        paymentDetails.walletType = selectedWalletType;
        paymentDetails.walletPhone = document.getElementById('walletPhone')?.value || null;
        if (selectedWalletType === 'other') {
          paymentDetails.customWalletName = document.getElementById('customWalletName')?.value || null;
        }
      } else if (selectedMethod === 'bank') {
        paymentDetails.bankRef = document.getElementById('bankRef')?.value || null;
        paymentDetails.transferProof = document.getElementById('transferProof')?.files[0] ? true : false;
      }

      const payload = {
        fundraiserKey: donationData.fundraiserId,
        amount: donationData.amount,
        paymentMethod: selectedMethod,
        paymentDetails,
        currency: 'usd'
      };

      const res = await fetch('/api/payments/create-invoice', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        const txt = await res.text().catch(() => null);
        throw new Error('فشل في إنشاء الفاتورة: ' + (txt || res.status));
      }
      const json = await res.json();
      return json.invoiceId;
    }

    // ---------- Request PaymentIntent ----------
    async function requestPaymentIntent(amountDollar, invoiceId, paymentMethodType = 'card') {
      const payload = {
        amount: Math.round(amountDollar * 100),
        currency: 'usd',
        fundraiserId: currentDonationData.fundraiserId,
        invoiceId,
        paymentMethodType
      };

      const res = await fetch('/api/payments/create-payment-intent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        const txt = await res.text().catch(() => null);
        return { success: false, error: txt || res.status };
      }
      return await res.json();
    }

    // ---------- Process wallet payment ----------
    async function processWalletPayment(amountDollar, invoiceId) {
      const payload = {
        amount: Math.round(amountDollar * 100),
        currency: 'usd',
        fundraiserId: currentDonationData.fundraiserId,
        invoiceId,
        walletType: selectedWalletType
      };

      const res = await fetch('/api/payments/process-wallet-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        const txt = await res.text().catch(() => null);
        return { success: false, error: txt || res.status };
      }
      return await res.json();
    }

    // ---------- Confirm card payment ----------
    async function processCardPayment(clientSecret) {
      if (!cardElementsMounted) {
        mountCardElements();
        await new Promise(r => setTimeout(r, 300));
        if (!cardElementsMounted) throw new Error('عنصر البطاقة غير جاهز. الرجاء إعادة فتح نافذة الدفع.');
      }

      const cardholderName = document.getElementById('cardholderName')?.value?.trim();
      if (!cardholderName) throw new Error('يرجى إدخال اسم حامل البطاقة');

      const result = await stripe.confirmCardPayment(clientSecret, {
        payment_method: {
          card: cardNumber,
          billing_details: { 
            name: cardholderName, 
            email: currentUser.email || undefined 
          }
        }
      });

      if (result.error) throw new Error(result.error.message);
      return result.paymentIntent;
    }

    // ---------- Main payment flow ----------
    async function processDonationPayment() {
      try {
        showLoading('جاري معالجة الدفع...');

        const donorName = document.getElementById('donorName')?.value?.trim();
        const amount = parseFloat(document.getElementById('donationAmount')?.value);
        if (!donorName) throw new Error('يرجى إدخال اسم المتبرع.');
        if (!amount || amount < 1) throw new Error('يرجى إدخال مبلغ تبرع صحيح (الحد الأدنى $1).');

        currentDonationData.donorName = donorName;
        currentDonationData.amount = amount;
        currentDonationData.paymentMethod = document.querySelector('input[name="paymentMethod"]:checked')?.value || 'card';

        // 1) Create invoice
        const invoiceId = await createInvoice(currentDonationData);
        console.log('Invoice created:', invoiceId);

        let paymentResult;

        if (currentDonationData.paymentMethod === 'card') {
          // 2) Card payment flow
          const pi = await requestPaymentIntent(amount, invoiceId, 'card');
          if (!pi.success) throw new Error(pi.error || 'فشل إنشاء PaymentIntent');

          // 3) Confirm card payment
          const paymentIntent = await processCardPayment(pi.clientSecret);
          if (paymentIntent && paymentIntent.status === 'succeeded') {
            paymentResult = { success: true, invoiceId, method: 'card' };
          } else {
            throw new Error('فشل في إتمام عملية الدفع');
          }

        } else if (currentDonationData.paymentMethod === 'wallet') {
          // Wallet payment flow
          const walletResult = await processWalletPayment(amount, invoiceId);
          if (!walletResult.success) throw new Error(walletResult.error || 'فشل معالجة الدفع بالمحفظة');
          paymentResult = { success: true, invoiceId, method: 'wallet', data: walletResult };

        } else if (currentDonationData.paymentMethod === 'bank') {
          // Bank transfer flow
          paymentResult = { 
            success: true, 
            invoiceId, 
            method: 'bank',
            bankRef: document.getElementById('bankRef')?.value 
          };
        }

        // Show success message
        if (paymentResult.success) {
          showSuccessMessage(paymentResult);
        }

      } catch (err) {
        console.error('Payment error:', err);
        showErrorMessage(err.message || 'حدث خطأ أثناء معالجة الدفع');
      } finally {
        hideLoading();
      }
    }

    // ---------- UI helpers ----------
    function showLoading(msg) {
      const modal = document.getElementById('loadingModal');
      const msgEl = document.getElementById('loadingMessage');
      if (msgEl) msgEl.textContent = msg || 'جاري المعالجة...';
      if (modal) modal.style.display = 'block';
    }

    function hideLoading() { 
      const modal = document.getElementById('loadingModal'); 
      if (modal) modal.style.display = 'none'; 
    }

    function showSuccessMessage(paymentResult) {
      const successModal = document.getElementById('successModal');
      const successMessage = document.getElementById('successMessage');
      
      let message = `تم إنشاء الفاتورة بنجاح! رقم الفاتورة: ${paymentResult.invoiceId}`;
      
      if (paymentResult.method === 'card') {
        message = `تم الدفع بنجاح!`;
      } else if (paymentResult.method === 'wallet') {
        message = `تم تقديم طلب الدفع عبر المحفظة. رقم الفاتورة: ${paymentResult.invoiceId}`;
      } else if (paymentResult.method === 'bank') {
        message = `تم إنشاء الفاتورة. رقم المرجع: ${paymentResult.bankRef}. يرجى إتمام التحويل البنكي.`;
      }
      
      if (successMessage) successMessage.textContent = message;
      if (successModal) successModal.style.display = 'block';
    }

    function showErrorMessage(msg) {
      alert('خطأ: ' + msg);
    }

    function resetForms() {
      document.getElementById('donationForm')?.reset();
      const pm = document.getElementById('paymentMethodModal');
      if (pm) {
        pm.querySelectorAll('input, select, textarea').forEach(i => { 
          if (i.type !== 'radio' && i.type !== 'file') i.value = ''; 
        });
        // Reset file input
        const fileInput = document.getElementById('transferProof');
        if (fileInput) fileInput.value = '';
      }
      document.getElementById('donationModal').style.display = 'none';
      document.getElementById('paymentMethodModal').style.display = 'none';
      document.getElementById('loadingModal').style.display = 'none';
      document.getElementById('successModal').style.display = 'none';
      
      // Reset wallet selection
      selectedWalletType = null;
      document.querySelectorAll('.wallet-option').forEach(opt => {
        opt.classList.remove('selected');
      });
      document.getElementById('walletPhoneGroup').style.display = 'none';
      document.getElementById('customWalletGroup').style.display = 'none';
      
      unmountCardElements();
    }

    // ---------- Wallet selection ----------
    function setupWalletSelection() {
      document.querySelectorAll('.wallet-option').forEach(option => {
        option.addEventListener('click', function() {
          // Remove selection from all options
          document.querySelectorAll('.wallet-option').forEach(opt => {
            opt.classList.remove('selected');
          });
          
          // Add selection to clicked option
          this.classList.add('selected');
          selectedWalletType = this.dataset.walletType;
          
          // Show/hide additional fields based on selection
          const walletPhoneGroup = document.getElementById('walletPhoneGroup');
          const customWalletGroup = document.getElementById('customWalletGroup');
          
          if (selectedWalletType === 'other') {
            walletPhoneGroup.style.display = 'block';
            customWalletGroup.style.display = 'block';
          } else if (selectedWalletType === 'zain_cash' || selectedWalletType === 'asia_hawala') {
            walletPhoneGroup.style.display = 'block';
            customWalletGroup.style.display = 'none';
          } else {
            walletPhoneGroup.style.display = 'none';
            customWalletGroup.style.display = 'none';
          }
        });
      });
    }

    // ---------- Payment method toggle ----------
    function setupPaymentMethodToggle() {
      const paymentMethods = document.querySelectorAll('input[name="paymentMethod"]');
      const cardFields = document.getElementById('cardPaymentFields');
      const walletFields = document.getElementById('walletPaymentFields');
      const bankFields = document.getElementById('bankPaymentFields');
      const summaryPaymentMethod = document.getElementById('summaryPaymentMethod');

      paymentMethods.forEach(pm => {
        pm.addEventListener('change', function () {
          const v = this.value;
          if (cardFields) cardFields.style.display = v === 'card' ? 'block' : 'none';
          if (walletFields) walletFields.style.display = v === 'wallet' ? 'block' : 'none';
          if (bankFields) bankFields.style.display = v === 'bank' ? 'block' : 'none';
          
          // Update summary
          if (summaryPaymentMethod) {
            if (v === 'card') summaryPaymentMethod.textContent = 'بطاقة ائتمان/خصم';
            else if (v === 'wallet') summaryPaymentMethod.textContent = 'محفظة إلكترونية';
            else if (v === 'bank') summaryPaymentMethod.textContent = 'تحويل بنكي';
          }
          
          if (v === 'card') setTimeout(mountCardElements, 120);
        });
      });
    }

    // ---------- Initialize donation events ----------
    function initializeDonationEvents() {
      // Updated: Use the donate button from your template
      const donateButton = document.getElementById('donateButton');
      if (donateButton) {
        donateButton.addEventListener('click', e => {
          e.preventDefault();
          openDonationModal();
        });
      }

      // Close buttons
      document.querySelectorAll('.close, #cancelBtn, #successCloseBtn').forEach(btn => {
        btn.addEventListener('click', () => {
          resetForms();
        });
      });

      // Donation form submission
      document.getElementById('donationForm')?.addEventListener('submit', e => {
        e.preventDefault();
        
        const donorName = document.getElementById('donorName')?.value?.trim();
        const donationAmount = parseFloat(document.getElementById('donationAmount')?.value);
        if (!donorName) return alert('يرجى إدخال اسم المتبرع.');
        if (!donationAmount || donationAmount < 1) return alert('الحد الأدنى $1');

        currentDonationData.donorName = donorName;
        currentDonationData.amount = donationAmount;
        
        // Update summary
        document.getElementById('summaryDonorName').textContent = donorName;
        document.getElementById('summaryAmount').textContent = donationAmount.toFixed(2);
        document.getElementById('summaryCampaign').textContent = currentDonationData.fundraiserTitle || '';
        
        // Set default payment method in summary
        const defaultMethod = document.querySelector('input[name="paymentMethod"]:checked')?.value;
        if (defaultMethod === 'card') {
          document.getElementById('summaryPaymentMethod').textContent = 'بطاقة ائتمان/خصم';
        }

        document.getElementById('donationModal').style.display = 'none';
        document.getElementById('paymentMethodModal').style.display = 'block';
        setTimeout(() => mountCardElements(), 200);
      });

      // Back button
      document.getElementById('backBtn')?.addEventListener('click', () => {
        document.getElementById('paymentMethodModal').style.display = 'none';
        document.getElementById('donationModal').style.display = 'block';
      });

      // Proceed to payment button
      document.getElementById('proceedPaymentBtn')?.addEventListener('click', () => {
        processDonationPayment();
      });

      // Close modals by clicking outside
      window.addEventListener('click', e => {
        const modals = ['donationModal', 'paymentMethodModal', 'loadingModal', 'successModal'];
        modals.forEach(modalId => {
          const modal = document.getElementById(modalId);
          if (e.target === modal) {
            modal.style.display = 'none';
            if (modalId !== 'loadingModal') resetForms();
          }
        });
      });
    }

    // ---------- Initialize application ----------
    document.addEventListener('DOMContentLoaded', async () => {
      await fetchCurrentUser();
      initializeStripe();
      setupPaymentMethodToggle();
      setupWalletSelection();
      initializeDonationEvents();
      
      // Debug: Log fundraiser data
      const fundraiserData = getFundraiserData();
      console.log('Fundraiser Data:', fundraiserData);
    });
  </script>
</body> 
