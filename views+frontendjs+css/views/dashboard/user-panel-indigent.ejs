  <script>
    // التحقق من بيانات الحملات عند التحميل
    document.addEventListener('DOMContentLoaded', () => {
      const fundraiserBoxes = document.querySelectorAll('.fundraiser-box');
      fundraiserBoxes.forEach(box => {
        const fundraiserId = box.getAttribute('data-id');
        const stripeBtn = box.querySelector('.stripe-btn');
        console.log(`Fundraiser ${fundraiserId}: Stripe button ${stripeBtn ? 'exists' : 'not found'}`);
      });
    });

    async function openStripeExpress(fundraiserId, evt) {
      try {
        // إظهار loading indicator
        const button = evt ? (evt.target.closest('.stripe-btn') || evt.target) : document.querySelector(`button[onclick*="openStripeExpress(${fundraiserId}"]`);
        const originalText = button ? button.innerHTML : '';
        if (button) {
          button.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:5px;"></i> Loading...';
          button.disabled = true;
        }

        // جلب رابط Stripe Express login
        const response = await fetch(`/api/payments/login/${fundraiserId}`);
        const data = await response.json();

        if (data.ok && data.loginUrl) {
          // فتح رابط Stripe Express في نافذة جديدة
          window.open(data.loginUrl, '_blank');
        } else {
          alert(data.error || 'فشل في الحصول على رابط Stripe Express');
        }
        
        // استعادة حالة الزر
        if (button) {
          button.innerHTML = originalText;
          button.disabled = false;
        }
      } catch (error) {
        console.error('Error opening Stripe Express:', error);
        alert('حدث خطأ أثناء محاولة فتح Stripe Express');
        // استعادة حالة الزر في حالة الخطأ
        const button = evt ? (evt.target.closest('.stripe-btn') || evt.target) : document.querySelector(`button[onclick*="openStripeExpress(${fundraiserId}"]`);
        if (button) {
          button.innerHTML = '<i class="fa fa-credit-card" style="margin-right:5px;"></i> Stripe Express';
          button.disabled = false;
        }
      }
    }
  </script>
