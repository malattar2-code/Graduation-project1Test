          <div class="my-fundraisers-sec">
            <div class="title">
              <h1 data-i18n="userPanelMyFundraisersTitleTgt">My Fundraisers :</h1>
            </div>
                    <style>
                    /* الخلفية الشفافة */
                    .modal {
                        display: none;
                        position: fixed;
                        z-index: 1000;
                        left: 0;
                        top: 0;
                        width: 100%;
                        height: 100%;
                        overflow: auto;
                        background-color: rgba(0, 0, 0, 0.6);
                        animation: fadeIn 0.3s;
                    }

                    /* محتوى النافذة */
                    .modal-content {
                        background-color: #fefefe;
                        margin: 10% auto;
                        padding: 20px;
                        border-radius: 10px;
                        width: 90%;
                        max-width: 400px;
                        text-align: center;
                        position: relative;
                        animation: slideDown 0.3s;
                    }

                    /* زر الإغلاق */
                    .modal .close {
                        position: absolute;
                        top: 10px;
                        right: 15px;
                        color: #aaa;
                        font-size: 24px;
                        cursor: pointer;
                    }

                    .modal .close:hover {
                        color: #000;
                    }

                    /* Spinner */
                    .spinner {
                        border: 5px solid #f3f3f3;
                        border-top: 5px solid #4CAF50;
                        border-radius: 50%;
                        width: 40px;
                        height: 40px;
                        margin: 20px auto;
                        animation: spin 1s linear infinite;
                    }

                    /* Animations */
                    @keyframes spin {
                        100% {
                            transform: rotate(360deg);
                        }
                    }

                    @keyframes fadeIn {
                        from {
                            opacity: 0;
                        }

                        to {
                            opacity: 1;
                        }
                    }

                    @keyframes slideDown {
                        from {
                            transform: translateY(-50px);
                        }

                        to {
                            transform: translateY(0);
                        }
                    }
                </style>
                <div id="receiveModal" class="modal">
                    <div class="modal-content">
                        <span class="close">&times;</span>
                        <div id="modal-body">
                            <div class="spinner"></div>
                            <p>Checking your Stripe account...</p>
                        </div>
                    </div>
                </div>
            <!-- Start Fundraiser Boxes -->
             <!-- Success/Error Messages -->
            <% if (successMessage) { %>
              <div class="alert success-alert">
                <i class="fa fa-check-circle"></i>
                <%= successMessage %>
              </div>
            <% } %>
            
            <% if (errorMessage) { %>
              <div class="alert error-alert">
                <i class="fa fa-exclamation-triangle"></i>
                <%= errorMessage %>
              </div>
            <% } %>

            <!-- Fundraisers Grid -->
            <div class="my-fundraisers-boxes">
              <% if (fundraisers && fundraisers.length > 0) { %>
                <% fundraisers.forEach(function(fundraiser) { %>
                  <!-- Start Fundraiser Box -->
                  <div class="fundraiser-box" data-id="<%= fundraiser.fundraiser_id %>">
                    <div class="fundraiser-img" style="background: url('<%= fundraiser.fundraiser_main_image %>') center/cover;"
                      onclick="window.location.href='/fundraiser/<%= fundraiser.fundraiser_id %>'"></div>
                    <div class="fundraiser-title">
                        <h2 class="main-title"><%= fundraiser.fundraiser_title %></h2>
                        <span class="user-location">
                            <%= typeof userLocation !== 'undefined' ? userLocation : 'Location not specified' %>
                        </span>
                    </div>
                    
                    <!-- Categories Display -->
                    <% if (fundraiser.fundraiser_categories && fundraiser.fundraiser_categories.length > 0) { %>
                      <div class="fundraiser-categories">
                        <% fundraiser.fundraiser_categories.forEach(function(category, index) { %>
                          <span class="category-tag"><%= category %></span><% if (index < fundraiser.fundraiser_categories.length - 1) { %><% } %>
                        <% }); %>
                      </div>
                    <% } %>
                    
                    <p class="fundraiser-des">
                      <%= fundraiser.fundraiser_description.length > 150 ? 
                          fundraiser.fundraiser_description.substring(0, 150) + '...' : 
                          fundraiser.fundraiser_description %>
                    </p>
                    
                    <div class="fundraiser-btns">
                      <!-- Start Donation bar -->
                      <div class="donation-bar">
                        <div class="donation-scale">
                          <div class="donation-progress" style="width: <%= fundraiser.progressWidth %>"></div>
                        </div>
                        <div class="donation-money-number">
                          <div class="money target-amount" data-goal="<%= fundraiser.fundraiser_target_amount %>">
                            $<%= Math.round(fundraiser.fundraiser_collected_amount) %> / $<%= Math.round(fundraiser.fundraiser_target_amount) %>
                          </div>
                        </div>
                      </div>
                      <!-- End Donation bar -->
                      
                      <!-- Progress Info -->
                      <!-- <div class="progress-info">
                        <span class="progress-text">
                          
                        </span>
                        <span class="progress-percentage">(<%= fundraiser.progress %>%)</span>
                      </div> -->
                      
                      <div class="flex-btns">
                        <% if (fundraiser.fundraiser_status==='completed' && fundraiser.fundraiser_collected_amount > 0) { %>
                          <a href="#" class="receive-btn"
                              data-fundraiser-id="<%= fundraiser.fundraiser_id %>"
                              style="padding:10px 20px; background:#4CAF50; color:#fff; border-radius:5px; text-decoration:none;">
                              Receive Now
                          </a>
                          <% } else if (fundraiser.fundraiser_status==='transferred') { %>
                              <span style="padding:10px 20px; background:#6c757d; color:#fff; border-radius:5px; display:inline-block;">
                                  ✅ تم التحويل
                              </span>
                              <button onclick="deleteFundraiser(<%= fundraiser.fundraiser_id %>)" class="delete-btn btn-website" style="margin-left:10px;">Delete</button>
                          <% } else { %>
                              <button onclick="deleteFundraiser(<%= fundraiser.fundraiser_id %>)" class="delete-btn btn-website" data-i18n="userPanelMyFundraisersDeleteBtnTgt">Delete</button>
                          <% } %>
                        
                        <!-- زر Stripe Express إذا كان الحساب موجود -->
                        <% 
                          var hasStripe = false;
                          var stripeId = '';
                          
                          if (fundraiser.hasStripeAccount === true) {
                            hasStripe = true;
                          } else if (fundraiser.stripeAccountId) {
                            stripeId = String(fundraiser.stripeAccountId);
                            if (stripeId && stripeId.length > 0) {
                              hasStripe = true;
                            }
                          } else if (fundraiser.user && fundraiser.user.stripeAccountId) {
                            stripeId = String(fundraiser.user.stripeAccountId);
                            if (stripeId && stripeId.length > 0) {
                              hasStripe = true;
                            }
                          }
                        %>
                        <% if (hasStripe) { %>
                          <button onclick="openStripeExpress(<%= fundraiser.fundraiser_id %>, event)" 
                                  class="stripe-btn btn-website" 
                                  style="padding:10px 20px; background:#635BFF; color:#fff; border-radius:5px; margin-left:10px; border:none; cursor:pointer;">
                              <i class="fa fa-credit-card" style="margin-right:5px;"></i>
                              Stripe Express
                          </button>
                        <% } %>
                      </div>
                      
                      <!-- Fundraiser Meta Info -->
                      <!-- <div class="fundraiser-meta">
                        <div class="meta-item">
                          <i class="fa fa-calendar"></i>
                          <span>Created: <%= new Date(fundraiser.created_at).toLocaleDateString() %></span>
                        </div>
                        <div class="meta-item">
                          <% if (fundraiser.firebase_id) { %>
                            <i class="fa fa-cloud" style="color: #28a745;"></i>
                            <span style="color: #28a745;" data-i18n="userPanelSyncedTgt">Synced</span>
                          <% } else { %>
                            <i class="fa fa-cloud-upload" style="color: #ffc107;"></i>
                            <span style="color: #ffc107;" data-i18n="userPanelPendingSyncTgt">Pending Sync</span>
                          <% } %>
                        </div>
                      </div> -->
                    </div>
                  </div>
                  <!-- End Fundraiser Box -->
                <% }); %>
              <% } else { %>
                <!-- Empty State -->
                <div class="empty-fundraisers-state">
                  <div class="empty-icon">
                    <i class="fa fa-heart-o"></i>
                  </div>
                  <h3 data-i18n="userPanelNoFundraisersTitle">No Fundraisers Yet</h3>
                  <p data-i18n="userPanelNoFundraisersDesc">You haven't created any fundraisers yet. Start by creating your first fundraiser using the form above.</p>
                  <button class="btn-website" onclick="scrollToAddForm()">
                    <i class="fa fa-plus"></i>
                    <span data-i18n="userPanelCreateFirstTgt">Create Your First Fundraiser</span>
                  </button>
                </div>
              <% } %>
            </div>
          </div>
