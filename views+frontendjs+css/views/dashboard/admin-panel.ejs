                                              </svg>
                                          </button>
                                      </form>
                                  </td>
                              </tr>
                          <% }); %>
                      <% } else { %>
                          <tr>
                              <td colspan="9" style="text-align: center;">No ranks found</td>
                          </tr>
                      <% } %>
