          <!-- Start All FAQs Table -->
          <div class="all-Faqs-table">
            <h2>All FAQs</h2>
            <table class="content-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Question</th>
                  <th>Answer</th>
                  <th>Type</th>
                  <th>Created Date</th>
                  <th class="th-btn">Actions</th>
                </tr>
              </thead>
              <tbody id="faqTableBody">
                <!-- FAQs will be dynamically loaded here -->
                <tr>
                  <td colspan="6" class="loading-text">Loading FAQs...</td>
                </tr>
              </tbody>
            </table>
          </div>
          <!-- End All FAQs Table -->
           <!-- Delete Confirmation Modal -->
          <div id="deleteModal" class="modal" style="display: none;">
            <div class="modal-content">
              <h3>Confirm Delete</h3>
              <p>Are you sure you want to delete this FAQ?</p>
              <div class="modal-actions">
                <button id="confirmDelete" class="btn-danger">Yes, Delete</button>
                <button id="cancelDelete" class="btn-secondary">Cancel</button>
              </div>
            </div>
          </div>
        </div>
        <!-- End Faq Settings -->
        <!-- Start Complaint Settings -->
        <div class="complaint-settings">
          <h1 class="title">Complaints Settings</h1>
          <div class="flex-content">
            <!-- Start All Complaints Number Box -->
            <div class="all-complaints-number-box">
              <img src="/assets/image/Admin-Panel-Page/banner.png" alt="">
              <h1>All Complaints</h1>
              <h2 id="complaints-count">0</h2> <!-- Added ID -->
            </div>
            <!-- End All Complaints Number Box -->
          </div>
          <!-- Start All Complaints Table -->
          <div class="all-complaints-table">
              <h2>All Complaints</h2>
              <table class="content-table">
                  <thead>
                      <tr>
                          <th>Id</th>
                          <th>Content</th>
                          <th>User Id</th>
                          <th>User email</th>
                          <th>User fullName</th>
                          <th>Status</th>
                          <th>Created At</th>
                          <th class="th-btn">Resolved</th>
                          <th class="th-btn">Delete</th>
                      </tr>
                  </thead>
                  <tbody id="complaintsTableBody">
                      <% if (allComplaints && allComplaints.length > 0) { %>
                          <% console.log('Rendering complaints in template, count:', allComplaints.length); %>
                          <% allComplaints.forEach(function(complaint, index) { %>
                              <% console.log('Rendering complaint:', complaint.complaint_id, complaint.status); %>
                              <tr id="complaint-<%= complaint.complaint_id %>">
                                  <td><%= complaint.complaint_id %></td>
                                  <td class="complaint-content">
                                      <div class="content-preview">
                                          <%= complaint.complaint_content && complaint.complaint_content.length > 100 ? 
                                              complaint.complaint_content.substring(0, 100) + '...' : 
                                              (complaint.complaint_content || 'No content') %>
                                      </div>
                                      <% if (complaint.complaint_content && complaint.complaint_content.length > 100) { %>
                                          <button class="view-more-btn" onclick="toggleComplaintContent(<%= complaint.complaint_id %>)">View More</button>
                                          <div class="full-content" id="full-content-<%= complaint.complaint_id %>" style="display: none;">
                                              <%= complaint.complaint_content %>
                                          </div>
                                      <% } %>
                                  </td>
                                  <td><%= complaint.user_id %></td>
                                  <td><%= complaint.user_email %></td>
                                  <td><%= complaint.user_full_name %></td>
                                  <td>
                                      <span class="status-badge status-<%= complaint.status %>">
                                          <%= complaint.status %>
                                      </span>
                                  </td>
                                  <td><%= complaint.created_at ? new Date(complaint.created_at).toLocaleDateString() : 'N/A' %></td>
                                  <td class="td-btn">
                                      <% if (complaint.status !== 'resolved') { %>
                                          <button class="resolve-btn" onclick="resolveComplaint(<%= complaint.complaint_id %>)">
                                              Resolve
                                          </button>
                                      <% } else { %>
                                          <span class="resolved-text">Resolved</span>
                                      <% } %>
                                  </td>
                                  <td class="td-btn">
                                      <button class="delete-btn" onclick="deleteComplaint(<%= complaint.complaint_id %>)">
                                          Delete
                                      </button>
                                  </td>
                              </tr>
                          <% }); %>
                      <% } else { %>
                          <% console.log('No complaints to render in template'); %>
                          <tr>
                              <td colspan="9" class="no-data">No complaints found</td>
                          </tr>
                      <% } %>
                  </tbody>
              </table>
          </div>
          <!-- End All Complaints Table -->
         </div>
        <!-- End Complaint Settings -->
      </div>
      <!-- End Admin Settings Dashboard Section -->
    </section>
    <!-- End Main Content Admin Panel -->
  </header>
  <!-- End Header -->
