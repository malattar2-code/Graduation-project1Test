                              },
                              tooltip: {
                                  callbacks: {
                                      label: function(context) {
                                          const label = context.label || '';
                                          const value = context.raw;
                                          const count = label === 'Has Rank' ? totalInRank : totalNotInRank;
                                          return `${label}: ${value}% (${count} Users)`;
                                      }
                                  }
                              }
                          },
                          cutout: '70%'
                      }
                  });
              });
            </script>
          </div>
