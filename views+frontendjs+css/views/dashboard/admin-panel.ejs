                                  <td><%= rank.rankName %></td>
                                  <td><%= rank.minimumPoints %></td>
                                  <td><%= rank.maximumPoints %></td>
                                  <td>
                                      <% if (rank.rankImage) { %>
                                          <img src="<%= rank.rankImage %>" alt="Rank Image" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                      <% } else { %>
                                          No Image
                                      <% } %>
                                  </td>
