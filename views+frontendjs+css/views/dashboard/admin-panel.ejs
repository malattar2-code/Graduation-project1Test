                    <canvas id="userChart"></canvas>
                </div>
            </div>
            <!-- End Total User Statistics -->
            <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Real data from server - replace sample data
                const totalDonors = <%- userStats.donors %>;
                const totalRequesters = <%- userStats.requesters %>;
                const totalUsers = <%- userStats.total %>;
                
                // Use calculated percentages from server
                const donorPercentage = <%- userStats.donorPercentage %>;
                const requesterPercentage = <%- userStats.requesterPercentage %>;
                
                const ctxUsers = document.getElementById('userChart').getContext('2d');
                
                new Chart(ctxUsers, {
                    type: 'doughnut',
                    data: {
                        labels: ['Donors', 'Indigents'],
                        datasets: [{
                            data: [donorPercentage, requesterPercentage],
                            backgroundColor: ['#ff9a17', '#14213d'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const label = context.label || '';
                                        const value = context.raw;
                                        const count = label === 'Donors' ? totalDonors : totalRequesters;
                                        return `${label}: ${value}% (${count} users)`;
                                    }
                                }
                            }
                        },
                        cutout: '70%'
                    }
                });
            });
