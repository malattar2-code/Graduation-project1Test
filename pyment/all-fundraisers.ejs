<script>

// Close menu when clicking outside
if (overlay) {
    overlay.addEventListener('click', closeMobileMenu);
}

// Prevent closing when clicking inside the menu
if (mobileMenu) {
    mobileMenu.addEventListener('click', function(e) {
        e.stopPropagation();
    });
}

// Close menu when pressing Escape key
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && mobileMenu.classList.contains('active')) {
        closeMobileMenu();
    }
});

// Handle window resize
window.addEventListener('resize', function() {
    if (window.innerWidth > 480 && mobileMenu.classList.contains('active')) {
        closeMobileMenu();
    }
});

document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-input');
    const categoryFilterInput = document.getElementById('categoryFilter');
    const searchForm = document.getElementById('searchForm');
    const autocompleteBox = document.getElementById('autocomplete-box');
    const suggestionsList = document.getElementById('suggestions-list');
    const recentTagsContainer = document.getElementById('recent-tags');
    const clearRecentBtn = document.getElementById('clear-recent');

    // Get categories from server-side data
    const categories = <%- typeof categories !== 'undefined' ? JSON.stringify(categories) : '[]' %>;

    // Recent searches from local storage
    let recentSearches = JSON.parse(localStorage.getItem('recentSearches')) || [];

    // Display recent searches
    function displayRecentSearches() {
        if (recentTagsContainer) {
            recentTagsContainer.innerHTML = '';
            recentSearches.slice(0, 5).forEach(search => {
                const tag = document.createElement('div');
                tag.className = 'recent-tag';
                tag.textContent = search;
                tag.addEventListener('click', () => {
                    // Clear both inputs first
                    searchInput.value = '';
                    categoryFilterInput.value = '';

                    // Check if this recent search matches a category
                    const categoryArray = Array.isArray(categories) ? categories : JSON.parse(categories);
                    if (categoryArray.includes(search)) {
                        // It's a category search
                        categoryFilterInput.value = search;
                    } else {
                        // It's a text search
                        searchInput.value = search;
                    }
                    searchForm.submit();
                });
                recentTagsContainer.appendChild(tag);
            });
        }
    }

    // Clear recent searches
    if (clearRecentBtn) {
        clearRecentBtn.addEventListener('click', () => {
            recentSearches = [];
            localStorage.setItem('recentSearches', JSON.stringify(recentSearches));
            displayRecentSearches();
        });
    }

    // Category suggestion click handler - FIXED
    document.querySelectorAll('.suggestion-item').forEach(item => {
        item.addEventListener('click', function() {
            const category = this.getAttribute('data-category');

            // Clear search input and set category filter
            searchInput.value = '';
            categoryFilterInput.value = category;

            addToRecentSearches(category);
            searchForm.submit();
        });
    });

    // Enhanced suggestion creation with proper event handling
    function showSuggestions(value) {
        if (suggestionsList) {
            // Clear previous suggestions
            suggestionsList.innerHTML = '';

            // Show/hide recent searches
            const recentContainer = document.getElementById('recent-searches-container');
            if (recentContainer) {
                recentContainer.style.display = 'none';
            }

            // Filter categories
            const categoryArray = Array.isArray(categories) ? categories : JSON.parse(categories);
            const filteredCategories = categoryArray.filter(category =>
                category.toLowerCase().includes(value.toLowerCase())
            );

            // Display filtered categories
            if (filteredCategories.length > 0) {
                filteredCategories.forEach(category => {
                    const item = document.createElement('div');
                    item.className = 'suggestion-item';
                    item.setAttribute('data-category', category);
                    item.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-hash" viewBox="0 0 16 16">
                            <path d="M8.39 12.648a1 1 0 0 0-.015.18c0 .305.21.508.5.508.266 0 .492-.172.555-.477l.554-2.703h1.204c.421 0 .617-.234.617-.547 0-.312-.188-.53-.617-.53h-.985l.516-2.524h1.265c.43 0 .618-.227.618-.547 0-.313-.188-.524-.618-.524h-1.046l.476-2.304a1 1 0 0 0 .016-.164.51.51 0 0 0-.516-.516.54.54 0 0 0-.539.43l-.523 2.554H7.617l.477-2.304c.008-.04.015-.118.015-.164a.51.51 0 0 0-.523-.516.54.54 0 0 0-.531.43L6.53 5.484H5.414c-.43 0-.617.22-.617.532s.187.539.617.539h.906l-.515 2.523H4.609c-.421 0-.609.219-.609.531s.188.547.61.547h.976l-.516 2.492c-.008.04-.015.125-.015.18 0 .305.21.508.5.508.265 0 .492-.172.554-.477l.555-2.703h2.242zm-1-6.109h2.266l-.515 2.563H6.859l.532-2.563z"/>
                        </svg> ${category}`;

                    // Add click event to the newly created item
                    item.addEventListener('click', function() {
                        searchInput.value = '';
                        categoryFilterInput.value = category;
                        addToRecentSearches(category);
                        searchForm.submit();
                    });

                    suggestionsList.appendChild(item);
                });
                if (autocompleteBox) autocompleteBox.classList.add('visible');
            } else {
                hideSuggestions();
            }
        }
    }

    // Add to recent searches
    function addToRecentSearches(search) {
        if (search && !recentSearches.includes(search)) {
            recentSearches.unshift(search);
            if (recentSearches.length > 5) {
                recentSearches.pop();
            }
            localStorage.setItem('recentSearches', JSON.stringify(recentSearches));
            displayRecentSearches();
        }
    }

    // Hide suggestions
    function hideSuggestions() {
        if (autocompleteBox) autocompleteBox.classList.remove('visible');
    }

    // Show suggestions when input is focused
    searchInput.addEventListener('focus', () => {
        if (searchInput.value.length > 0) {
            showSuggestions(searchInput.value);
        } else {
            showAutocompleteBox();
        }
    });

    // Handle input
    searchInput.addEventListener('input', () => {
        const value = searchInput.value;
        if (value.length > 0) {
            showSuggestions(value);
        } else {
            showAutocompleteBox();
        }
    });

    // Show autocomplete box
    function showAutocompleteBox() {
        const recentContainer = document.getElementById('recent-searches-container');
        if (recentContainer) {
            recentContainer.style.display = recentSearches.length > 0 ? 'block' : 'none';
        }
        if (autocompleteBox) autocompleteBox.classList.add('visible');
    }

    // Hide suggestions when clicking outside
    document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && (!autocompleteBox || !autocompleteBox.contains(e.target))) {
            hideSuggestions();
        }
    });

    // Handle form submission - clear category filter for manual searches
    searchForm.addEventListener('submit', (e) => {
        const searchValue = searchInput.value.trim();

        // If user is typing manually (not using suggestions), clear category filter
        if (searchValue && !categoryFilterInput.value) {
            categoryFilterInput.value = ''; // Ensure category is cleared for manual searches
        }

        if (searchValue.length > 0 || categoryFilterInput.value.length > 0) {
            addToRecentSearches(searchValue || categoryFilterInput.value);
        }
    });

    // Initial display of recent searches
    displayRecentSearches();


    });
// Enhanced Show More functionality
function initializeShowMoreButtons() {
    console.log('🔧 DOM loaded - initializing show more buttons');
    const mainContentAllFundraisers = document.querySelector('.main-content-all-fundraisers');
    const showMoreButtons = document.querySelectorAll('.show-more-btn');
    console.log(`🔧 Found ${showMoreButtons.length} show more buttons`);

    showMoreButtons.forEach((button, index) => {
        console.log(`🔧 Button ${index + 1}:`, {
            section: button.dataset.section,
            currentPage: button.dataset.currentPage,
            totalPages: button.dataset.totalPages,
            element: button
        });

        button.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('🔄 Show More button clicked:', {
                section: this.dataset.section,
                currentPage: this.dataset.currentPage,
                totalPages: this.dataset.totalPages,
                element: this
            });

            const section = this.dataset.section;
            const currentPage = parseInt(this.dataset.currentPage);
            const totalPages = parseInt(this.dataset.totalPages);
            const nextPage = currentPage + 1;

            console.log(`📄 Section: ${section}, Current: ${currentPage}, Next: ${nextPage}, Total: ${totalPages}`);

            if (nextPage > totalPages) {
                console.log('❌ No more pages available');
                return;
            }

            loadMoreFundraisers(section, nextPage, this);
        });
    });
}

async function loadMoreFundraisers(section, page, buttonElement) {
    console.log(`🚀 Loading more fundraisers for ${section}, page ${page}`);

    try {
        // Show loading state
        const originalHTML = buttonElement.innerHTML;
        buttonElement.innerHTML = '<h1>Loading...</h1>';
        buttonElement.disabled = true;

        // Build URL with parameters
        const params = new URLSearchParams({
            section: section,
            page: page
        });

        // Add search parameters for search results
        if (section === 'search') {
            params.append('search', buttonElement.dataset.searchQuery || '');
            params.append('category', buttonElement.dataset.categoryFilter || '');
        }

        const url = `/all-fundraisers/load-more?${params.toString()}`;
        console.log(`🌐 Making request to: ${url}`);

        const response = await fetch(url);
        console.log(`📥 Response status: ${response.status}`);

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        console.log(`✅ Received data for ${section}:`, {
            fundraisersCount: data.fundraisers ? data.fundraisers.length : 0,
            currentPage: data.currentPage,
            totalPages: data.totalPages,
            hasMore: data.hasMore
        });

        // Find the correct container
        let containerId;
        switch(section) {
            case 'latest': containerId = 'latestFundraisersContainer'; break;
            case 'popular': containerId = 'popularFundraisersContainer'; break;
            case 'local': containerId = 'localFundraisersContainer'; break;
            case 'almostDone': containerId = 'almostDoneFundraisersContainer'; break;
            case 'search': containerId = 'searchResultsContainer'; break;
            case 'saved': containerId = 'savedFundraisersContainer'; break;
        }

        const container = document.getElementById(containerId);
        console.log(`📦 Container found:`, container);

        if (container && data.fundraisers && data.fundraisers.length > 0) {
            // Create HTML for new fundraisers
            const newFundraisersHTML = data.fundraisers.map(fundraiser => `
                <div class="fundraiser-box" data-fundraiser-id="${fundraiser.fundraiser_id}">
                    <div class="fundraiser-account"
                        onclick="window.location.href='/indigent-account/${fundraiser.fundraiser_user_id}'"
                        style="cursor: pointer;">
                        ${fundraiser.user_image ?
                            `<img src="${fundraiser.user_image}" alt="${fundraiser.user_name}'s Profile" onerror="this.src='/images/default-profile.png'">` :
                            `<img src="/images/default-profile.png" alt="Default Profile">`
                        }
                        <h1 class="account-name">${fundraiser.user_name}</h1>
                    </div>
                    <div class="fundraiser-img"
                        style="background: url('${fundraiser.fundraiser_main_image}') center/cover; cursor: pointer;"
                        onclick="window.location.href='/fundraiser/${fundraiser.fundraiser_id}'">
                    </div>
                    <div class="fundraiser-title">
                        <h2 class="main-title">${fundraiser.fundraiser_title}</h2>
                        <span>${fundraiser.user_location}</span>
                    </div>

                    ${fundraiser.fundraiser_categories && fundraiser.fundraiser_categories.length > 0 ? `
                        <div class="fundraiser-categories">
                            ${fundraiser.fundraiser_categories.map(category =>
                                `<span class="category-tag">${category}</span>`
                            ).join('')}
                        </div>
                    ` : ''}

                    <p class="fundraiser-des">
                        ${fundraiser.fundraiser_description.length > 150 ?
                            fundraiser.fundraiser_description.substring(0, 150) + '...' :
                            fundraiser.fundraiser_description}
                    </p>

                    <div class="fundraiser-btns">
                        <div class="flex-btns">
                            <a class="donate-later-btn btn-website save-fundraiser-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-bookmark-plus" viewBox="0 0 16 16">
                                    <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1z"/>
                                    <path d="M8 4a.5.5 0 0 1 .5.5V6H10a.5.5 0 0 1 0 1H8.5v1.5a.5.5 0 0 1-1 0V7H6a.5.5 0 0 1 0-1h1.5V4.5A.5.5 0 0 1 8 4"/>
                                </svg>
                            </a>

                            <div class="donation-bar">
                                <div class="donation-scale">
                                    <div class="donation-progress" style="width: ${fundraiser.progressWidth}"></div>
                                </div>
                                <div class="donation-money-number">
                                    <div class="money" data-goal="${fundraiser.fundraiser_target_amount}">
                                        $${fundraiser.fundraiser_collected_amount} / $${fundraiser.fundraiser_target_amount}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <a href="/fundraiser/${fundraiser.fundraiser_id}" class="donate-btn btn-website" data-i18n="allFundraisersDonateBtnTgt">Donate</a>
                    </div>
                </div>
            `).join('');

            // Append new fundraisers
            container.innerHTML += newFundraisersHTML;
            console.log(`✅ Added ${data.fundraisers.length} new fundraisers to ${containerId}`);

            // 🔥 NEW: Update min-height of main content container
            updateMainContentHeight();

            // Update button state
            if (data.hasMore) {
                buttonElement.dataset.currentPage = data.currentPage;
                buttonElement.innerHTML = originalHTML;
                buttonElement.disabled = false;
                console.log(`🔄 Button updated - next page: ${data.currentPage + 1}`);
            } else {
                buttonElement.closest('.show-more-box').remove();
                console.log('🗑️ Button removed - no more pages');
            }

        } else {
            console.log('❌ No container or no fundraisers found');
            buttonElement.innerHTML = originalHTML;
            buttonElement.disabled = false;
        }

    } catch (error) {
        console.error('💥 Error loading more fundraisers:', error);
        buttonElement.innerHTML = '<h1>Error - Try Again</h1>';
        buttonElement.disabled = false;

        // Re-enable after 3 seconds
        setTimeout(() => {
            buttonElement.innerHTML = originalHTML;
            buttonElement.disabled = false;
        }, 3000);
    }
}

// 🔥 ALTERNATIVE: Function to incrementally increase height
function updateMainContentHeight() {
    const mainContent = document.querySelector('.main-content-all-fundraisers');
    if (mainContent) {
        // Get current min-height or use default
        const currentMinHeight = mainContent.style.minHeight || '100vh';

        // Convert to pixels for calculation (rough estimation)
        let currentHeightValue;
        if (currentMinHeight.includes('vh')) {
            currentHeightValue = parseFloat(currentMinHeight);
            // Add 70vh each time (100vh → 170vh → 240vh, etc.)
            const newHeightValue = currentHeightValue + 70;
            mainContent.style.minHeight = `${newHeightValue}vh`;
        } else {
            // Fallback to 170vh if we can't parse the current value
            mainContent.style.minHeight = '220vh';
        }

        console.log(`📏 Increased main content min-height to ${mainContent.style.minHeight}`);
    }
}
