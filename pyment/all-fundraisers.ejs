        <div class="search-filed-and-list-btn">
          <!-- Search Container -->
          <div class="search-container">
              <form action="/all-fundraisers" method="get" class="search-field" id="searchForm">
                  <input type="text"
                        id="search-input"
                        name="search"
                        value="<%= searchQuery %>"
                        data-i18n="searchPlaceholder"
                        placeholder="Search by title, description, or category..."
                        autocomplete="off">

                  <!-- Hidden input for category filter -->
                  <input type="hidden" name="category" id="categoryFilter" value="<%= categoryFilter %>">

                  <button type="submit" class="search-btn">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                      </svg>
                  </button>

