<!-- نافذة النجاح -->
<div id="successModal" class="modal" style="display: none;">
  <div class="modal-content loading-content">
    <svg style="color: #4CAF50; width: 80px; height: 80px; margin-bottom: 30px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
      <path d="M22 4L12 14.01l-3-3"/>
    </svg>
    <h3 data-i18n="paymentSuccess">تم الدفع بنجاح!</h3>
    <p id="successMessage">شكرًا لتبرعك!</p>
    <div class="form-buttons">
      <button type="button" id="successCloseBtn" onclick="closeModal('successModal')" data-i18n="close">إغلاق</button>
    </div>
  </div>
</div>

  <div id="successModal" class="modal">
    <div class="modal-content loading-content">
      <div style="color: #4CAF50; font-size: 48px; margin-bottom: 20px;">✓</div>
      <h3 data-i18n="paymentSuccess">تم الدفع بنجاح!</h3>
      <p id="successMessage"></p>
      <div class="form-buttons">
        <button type="button" id="successCloseBtn" data-i18n="close">إغلاق</button>
      </div>
    </div>
  </div>
  <script>
  const STRIPE_PUBLIC_KEY = 'pk_test_51SBtChDAEAM6yuRiFQzCs0fEXOKoHZ10lCV3PJGxPb1TTYOkpL0gFmE3IEnqmEC3bjNrGehL3n9M3bZdjop3nRJV00AgWo6i4B';

  let currentDonationData = {};
  let currentUser = {};
  let stripe = null;
  let elements = null;
  let cardNumber = null;
  let cardExpiry = null;
  let cardCvc = null;
  let cardElementsMounted = false;
  let mountRetryTimer = null;
  let selectedWalletType = null;
  let invoiceId = null;

  // ---------- Initialize Stripe ----------
  function initializeStripe() {
    if (!window.Stripe) {
      console.error('Stripe.js not loaded');
      return;
    }
    stripe = Stripe(STRIPE_PUBLIC_KEY);
    elements = stripe.elements();

    const style = {
      base: {
        fontSize: '16px',
        color: '#32325d',
        fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
        '::placeholder': { color: '#aab7c4' }
      },
      invalid: {
        color: '#fa755a',
        iconColor: '#fa755a'
      }
    };

    cardNumber = elements.create('cardNumber', { style, placeholder: '4242 4242 4242 4242' });
    cardExpiry = elements.create('cardExpiry', { style });
    cardCvc = elements.create('cardCvc', { style });

    const cardErrorEl = () => document.getElementById('card-errors');
    cardNumber.on('change', e => {
      if (cardErrorEl()) {
        cardErrorEl().textContent = e.error ? e.error.message : '';
        cardErrorEl().style.display = e.error ? 'block' : 'none';
      }
    });
    cardExpiry.on('change', e => {
      if (cardErrorEl()) {
        cardErrorEl().textContent = e.error ? e.error.message : '';
        cardErrorEl().style.display = e.error ? 'block' : 'none';
      }
    });
    cardCvc.on('change', e => {
      if (cardErrorEl()) {
        cardErrorEl().textContent = e.error ? e.error.message : '';
        cardErrorEl().style.display = e.error ? 'block' : 'none';
      }
    });
  }

  // ---------- Mount/unmount helpers ----------
  function mountCardElements(retryInterval = 150) {
    if (cardElementsMounted) return;
    const numContainer = document.getElementById('card-element');
    const expContainer = document.getElementById('card-expiry');
    const cvcContainer = document.getElementById('card-cvc');

    if (!numContainer || !expContainer || !cvcContainer) {
      if (mountRetryTimer) clearTimeout(mountRetryTimer);
      mountRetryTimer = setTimeout(() => mountCardElements(retryInterval), retryInterval);
      return;
    }

    try {
      cardNumber.mount('#card-element');
      cardExpiry.mount('#card-expiry');
      cardCvc.mount('#card-cvc');
      cardElementsMounted = true;
      if (mountRetryTimer) { clearTimeout(mountRetryTimer); mountRetryTimer = null; }
      console.log('✅ Stripe Elements mounted');
    } catch (err) {
      console.warn('Retry mounting Stripe Elements', err);
      if (mountRetryTimer) clearTimeout(mountRetryTimer);
      mountRetryTimer = setTimeout(() => mountCardElements(retryInterval), retryInterval);
    }
  }

  function unmountCardElements() {
    try {
      if (cardElementsMounted) {
        cardNumber.unmount();
        cardExpiry.unmount();
        cardCvc.unmount();
        cardElementsMounted = false;
        console.log('🧹 Stripe Elements unmounted');
      }
    } catch (err) {
      console.warn('Error during unmount:', err);
    }
  }

  // ---------- Fetch current user ----------
  async function fetchCurrentUser() {
    try {
      const res = await fetch('/api/payments/me', { credentials: 'include' });
      if (!res.ok) throw new Error('فشل في جلب بيانات المستخدم');
      const data = await res.json();
      currentUser = { uid: data.uid || null, name: data.name || 'مستخدم مجهول', email: data.email || null };
      const donorInput = document.getElementById('donorName');
      if (donorInput) donorInput.value = currentUser.name;
    } catch (err) {
      console.error('fetchCurrentUser error:', err);
      currentUser = { uid: null, name: 'مستخدم مجهول', email: null };
    }
  }

  // ---------- Open modal ----------
  function openDonationModal(fundraiserBox) {
    const fundraiserId = fundraiserBox.dataset.fundraiserId;
    const fundraiserTitle = fundraiserBox.querySelector('.main-title')?.textContent || '';
    const targetAmount = fundraiserBox.querySelector('.money')?.dataset.goal || '';

    currentDonationData = {
      fundraiserId,
      fundraiserTitle,
      donorName: currentUser.name || 'مستخدم مجهول',
      donorId: currentUser.uid || null,
      targetAmount: parseFloat(targetAmount || 0)
    };

    document.getElementById('fundraiserId').value = fundraiserId;
    document.getElementById('fundraiserTitle').value = fundraiserTitle;
    document.getElementById('targetAmount').value = targetAmount;
    document.getElementById('donorName').value = currentUser.name || 'مستخدم مجهول';

    document.getElementById('donationModal').style.display = 'block';
    setTimeout(() => mountCardElements(), 200);
  }

  // ---------- Create invoice ----------
  async function createInvoice(donationData) {
    const selectedMethod = donationData.paymentMethod || 'card';
    let paymentDetails = {
      donorName: donationData.donorName,
      donorEmail: currentUser.email || null
    };

    const payload = {
      fundraiserKey: donationData.fundraiserId,
      amount: donationData.amount,
      paymentMethod: selectedMethod,
      paymentDetails,
      currency: 'usd'
    };

    const res = await fetch('/api/payments/create-invoice', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(payload)
    });

    if (!res.ok) {
      const txt = await res.text().catch(() => null);
      throw new Error('فشل في إنشاء الفاتورة: ' + (txt || res.status));
    }
    const json = await res.json();
    return json.invoiceId;
  }

  // ---------- Request PaymentIntent ----------
  async function requestPaymentIntent(amountDollar, invoiceId, paymentMethod = 'card') {
    const payload = {
      amount: Math.round(amountDollar * 100),
      currency: 'usd',
      fundraiserId: currentDonationData.fundraiserId,
      invoiceId,
      paymentMethod
    };

    const res = await fetch('/api/payments/create-payment-intent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(payload)
    });

    if (!res.ok) {
      const txt = await res.text().catch(() => null);
      return { success: false, error: txt || res.status };
    }
    return await res.json();
}


  // ---------- Confirm card payment ----------
  async function processCardPayment(clientSecret) {
    if (!cardElementsMounted) {
      mountCardElements();
      await new Promise(r => setTimeout(r, 300));
      if (!cardElementsMounted) throw new Error('عنصر البطاقة غير جاهز. الرجاء إعادة فتح نافذة الدفع.');
    }

    const cardholderName = document.getElementById('cardholderName')?.value?.trim();
    if (!cardholderName) throw new Error('يرجى إدخال اسم حامل البطاقة');

    const result = await stripe.confirmCardPayment(clientSecret, {
      payment_method: {
        card: cardNumber,
        billing_details: {
          name: cardholderName,
          email: currentUser.email || undefined
        }
      }
    });

    if (result.error) throw new Error(result.error.message);
    return result.paymentIntent;
  }

  // ---------- Setup Google Pay Button ----------
  async function setupGooglePayButton() {
    try {
      if (!invoiceId) {
        invoiceId = await createInvoice(currentDonationData);
      }

      const pi = await requestPaymentIntent(currentDonationData.amount, invoiceId, 'google_pay');
      if (!pi.success) {
        throw new Error(pi.error || 'فشل إنشاء PaymentIntent');
      }

      const paymentRequest = stripe.paymentRequest({
        country: 'US',
        currency: 'usd',
        total: {
          label: `Donation to ${currentDonationData.fundraiserTitle}`,
          amount: Math.round(currentDonationData.amount * 100),
        },
        requestPayerName: true,
        requestPayerEmail: true,
      });

      const prButton = elements.create('paymentRequestButton', {
        paymentRequest,
      });

      const result = await paymentRequest.canMakePayment();
      if (result?.googlePay) {
        prButton.mount('#payment-request-button');
      } else {
        document.getElementById('payment-request-button').innerHTML = '<p>Google Pay غير متوفر على جهازك. يرجى اختيار طريقة دفع أخرى.</p>';
      }

      paymentRequest.on('paymentmethod', async (ev) => {
        showLoading('جاري معالجة الدفع عبر Google Pay...');

        const { paymentIntent, error: confirmError } = await stripe.confirmCardPayment(
          pi.clientSecret,
          { payment_method: ev.paymentMethod.id },
          { handleActions: false }
        );

        if (confirmError) {
          ev.complete('fail');
          showErrorMessage(confirmError.message);
        } else {
          ev.complete('success');
          if (paymentIntent.status === 'requires_action') {
            const { error } = await stripe.confirmCardPayment(pi.clientSecret);
            if (error) {
              showErrorMessage(error.message);
            } else {
              showSuccessMessage({ success: true, invoiceId, method: 'google_pay' });
            }
          } else {
            showSuccessMessage({ success: true, invoiceId, method: 'google_pay' });
          }
        }

        hideLoading();
      });

    } catch (err) {
      console.error('Google Pay setup error:', err);
      showErrorMessage(err.message || 'حدث خطأ أثناء إعداد Google Pay');
    }
  }

  // ---------- Adjust Proceed Button ----------
  function adjustProceedButton(walletType) {
    const proceedBtn = document.getElementById('proceedPaymentBtn');
    if (walletType === 'googlepay') {
      proceedBtn.style.display = 'none';
      setupGooglePayButton();
    } else {
      proceedBtn.style.display = 'block';
    }
  }

  // ---------- Main payment flow ----------
  async function processDonationPayment() {
    try {
      showLoading('جاري معالجة الدفع...');

      const activePaymentTab = document.querySelector('.payment-tab.active').dataset.tab;
      let paymentMethod;
      if (activePaymentTab === 'card') {
        paymentMethod = 'card';
      } else if (activePaymentTab === 'wallet') {
        const activeWalletTab = document.querySelector('.wallet-tab.active').getAttribute('data-tab');
        paymentMethod = activeWalletTab === 'googlepay' ? 'google_pay' : 'alipay';
      }
      currentDonationData.paymentMethod = paymentMethod;

      const amount = currentDonationData.amount;

      if (!invoiceId) {
        invoiceId = await createInvoice(currentDonationData);
        console.log('Invoice created:', invoiceId);
      }

      let paymentResult;

      if (paymentMethod === 'card') {
        const pi = await requestPaymentIntent(amount, invoiceId, 'card');
        if (!pi.success) throw new Error(pi.error || 'فشل إنشاء PaymentIntent');

        const paymentIntent = await processCardPayment(pi.clientSecret);
        if (paymentIntent && paymentIntent.status === 'succeeded') {
          paymentResult = { success: true, invoiceId, method: 'card' };
        } else {
          throw new Error('فشل في إتمام عملية الدفع');
        }
      } else if (paymentMethod === 'alipay') {
        const pi = await requestPaymentIntent(amount, invoiceId, 'alipay');
        if (!pi.success) throw new Error(pi.error || 'فشل إنشاء PaymentIntent');

        if (pi.redirectUrl) {
          window.location.href = pi.redirectUrl;
          return; // No further processing after redirect
        } else {
          throw new Error('لم يتم توفير رابط التوجيه لـ AliPay');
        }
      }

      // Show success message
      if (paymentResult?.success) {
        showSuccessMessage(paymentResult);
      }

    } catch (err) {
      console.error('Payment error:', err);
      showErrorMessage(err.message || 'حدث خطأ أثناء معالجة الدفع');
    } finally {
      hideLoading();
    }
  }

  // ---------- UI helpers ----------
  function showLoading(msg) {
    const modal = document.getElementById('loadingModal');
    const msgEl = document.getElementById('loadingMessage');
    if (msgEl) msgEl.textContent = msg || 'جاري المعالجة...';
    if (modal) modal.style.display = 'block';
  }

  function hideLoading() {
    const modal = document.getElementById('loadingModal');
    if (modal) modal.style.display = 'none';
  }

  function showSuccessMessage(paymentResult) {
    const successModal = document.getElementById('successModal');
    const successMessage = document.getElementById('successMessage');

    let message = `تم إنشاء الفاتورة بنجاح! رقم الفاتورة: ${paymentResult.invoiceId}`;

    if (paymentResult.method === 'card' || paymentResult.method === 'google_pay') {
      message = `تم الدفع بنجاح! رقم الفاتورة: ${paymentResult.invoiceId}`;
    }

    if (successMessage) successMessage.textContent = message;
    if (successModal) successModal.style.display = 'block';
  }

  function showErrorMessage(msg) {
    alert('خطأ: ' + msg);
  }

  function resetForms() {
    document.getElementById('donationForm')?.reset();
    const pm = document.getElementById('paymentMethodModal');
    if (pm) {
      pm.querySelectorAll('input, select, textarea').forEach(i => {
        if (i.type !== 'radio' && i.type !== 'file') i.value = '';
      });
    }
    document.getElementById('donationModal').style.display = 'none';
    document.getElementById('paymentMethodModal').style.display = 'none';
    document.getElementById('loadingModal').style.display = 'none';
    document.getElementById('successModal').style.display = 'none';

    // Reset wallet selection
    selectedWalletType = null;
    document.querySelectorAll('.wallet-tab').forEach(opt => {
      opt.classList.remove('active');
    });
    document.querySelector('.wallet-tab[data-tab="googlepay"]').classList.add('active');
    document.querySelectorAll('.wallet-tab-content').forEach(c => {
      c.classList.remove('active');
    });
    document.getElementById('googlepay').classList.add('active');

    unmountCardElements();
    invoiceId = null;
  }

  // ---------- Get wallet display name ----------
  function getWalletDisplayName(walletType) {
    const walletNames = {
      'googlepay': 'Google Pay',
      'alipay': 'AliPay'
    };
    return walletNames[walletType] || 'محفظة إلكترونية';
  }

  // ---------- Update payment method summary ----------
  function updatePaymentMethodSummary(method, displayName = '') {
    const summaryPaymentMethod = document.getElementById('summaryPaymentMethod');
    if (summaryPaymentMethod) {
      if (method === 'card') {
        summaryPaymentMethod.textContent = 'بطاقة ائتمان/خصم';
      } else if (method === 'wallet') {
        summaryPaymentMethod.textContent = displayName;
      }
    }
  }

  // ---------- Payment method toggle ----------
  function setupPaymentMethodToggle() {
    const paymentTabs = document.querySelectorAll('.payment-tab');
    const paymentFields = document.querySelectorAll('.payment-fields');

    paymentTabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const tabType = this.getAttribute('data-tab');

        // إزالة النشاط من جميع التبويبات والمحتويات
        paymentTabs.forEach(t => t.classList.remove('active'));
        paymentFields.forEach(f => f.style.display = 'none');

        // إضافة النشاط للتبويب المحدد
        this.classList.add('active');

        // إظهار الحقول المناسبة
        if (tabType === 'card') {
          document.getElementById('cardPaymentFields').style.display = 'block';
          setTimeout(mountCardElements, 120);
          updatePaymentMethodSummary('card');
          document.getElementById('proceedPaymentBtn').style.display = 'block';
        } else if (tabType === 'wallet') {
          document.getElementById('walletPaymentFields').style.display = 'block';
          const activeWalletTab = document.querySelector('.wallet-tab.active').getAttribute('data-tab');
          updatePaymentMethodSummary('wallet', getWalletDisplayName(activeWalletTab));
          adjustProceedButton(activeWalletTab);
        }
      });
    });
  }

  // ---------- Initialize wallet payment ----------
  function initializeWalletPayment() {
    // إعداد تبويبات المحافظ الإلكترونية
    const walletTabs = document.querySelectorAll('.wallet-tab');
    const walletContents = document.querySelectorAll('.wallet-tab-content');

    walletTabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const tabId = this.getAttribute('data-tab');

        // إزالة النشاط من جميع التبويبات والمحتويات
        walletTabs.forEach(t => t.classList.remove('active'));
        walletContents.forEach(c => c.classList.remove('active'));

        // إضافة النشاط للتبويب والمحتوى المحدد
        this.classList.add('active');
        document.getElementById(tabId).classList.add('active');

        // تحديث نوع المحفظة المختارة
        selectedWalletType = tabId;

        // تحديث ملخص طريقة الدفع
        updatePaymentMethodSummary('wallet', getWalletDisplayName(tabId));

        // ضبط زر الإتمام
        adjustProceedButton(tabId);
      });
    });
  }

  // ---------- Initialize donation events ----------
  function initializeDonationEvents() {
    document.querySelectorAll('.donate-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        openDonationModal(btn.closest('.fundraiser-box'));
      });
    });

    // Close buttons
    document.querySelectorAll('.close, #cancelBtn, #successCloseBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        resetForms();
      });
    });

    // Donation form submission
    document.getElementById('donationForm')?.addEventListener('submit', async e => {
      e.preventDefault();

      const donorName = document.getElementById('donorName')?.value?.trim();
      const donationAmount = parseFloat(document.getElementById('donationAmount')?.value);
      if (!donorName) return alert('يرجى إدخال اسم المتبرع.');
      if (!donationAmount || donationAmount < 1) return alert('الحد الأدنى $1');

      currentDonationData.donorName = donorName;
      currentDonationData.amount = donationAmount;

      // Create invoice here (without specific payment method yet)
      try {
        invoiceId = await createInvoice(currentDonationData);
      } catch (err) {
        return showErrorMessage('فشل في إنشاء الفاتورة');
      }

      // Update summary
      document.getElementById('summaryDonorName').textContent = donorName;
      document.getElementById('summaryAmount').textContent = donationAmount.toFixed(2);
      document.getElementById('summaryCampaign').textContent = currentDonationData.fundraiserTitle || '';
      document.getElementById('summaryPaymentMethod').textContent = 'بطاقة ائتمان/خصم'; // Default

      document.getElementById('donationModal').style.display = 'none';
      document.getElementById('paymentMethodModal').style.display = 'block';
      setTimeout(() => mountCardElements(), 200);
    });

    // Back button
    document.getElementById('backBtn')?.addEventListener('click', () => {
      document.getElementById('paymentMethodModal').style.display = 'none';
      document.getElementById('donationModal').style.display = 'block';
    });

    // Proceed to payment button
    document.getElementById('proceedPaymentBtn')?.addEventListener('click', () => {
      processDonationPayment();
    });

    // Close modals by clicking outside
    window.addEventListener('click', e => {
      const modals = ['donationModal', 'paymentMethodModal', 'loadingModal', 'successModal'];
      modals.forEach(modalId => {
        const modal = document.getElementById(modalId);
        if (e.target === modal) {
          modal.style.display = 'none';
          if (modalId !== 'loadingModal') resetForms();
        }
      });
    });
  }

  // ---------- Initialize application ----------
  document.addEventListener('DOMContentLoaded', async () => {
    await fetchCurrentUser();
    initializeStripe();
    setupPaymentMethodToggle();
    initializeWalletPayment();
    initializeDonationEvents();
    selectedWalletType = 'googlepay';
  });
</script>
</body>
