

<!-- Donation Modal Overlay -->
<div id="donationModal" class="donation-modal-overlay" style="display: none;">
  <div class="donation-modal">
    <!-- Close Button -->
    <button class="donation-modal__close" id="donationModalClose" aria-label="Close donation modal">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Modal Header -->
    <div class="donation-modal__header">
      <div class="donation-modal__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ff9a17" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      </div>
      <h2 class="donation-modal__title">Make a Donation</h2>
      <p class="donation-modal__subtitle">Your contribution makes a real difference</p>
    </div>

    <!-- Step 1: Amount Selection -->
    <div class="donation-modal__step" id="donationStep1">
      <div class="donation-modal__amount-presets">
        <button class="donation-modal__preset-btn" data-amount="10">$10</button>
        <button class="donation-modal__preset-btn" data-amount="25">$25</button>
        <button class="donation-modal__preset-btn" data-amount="50">$50</button>
        <button class="donation-modal__preset-btn" data-amount="100">$100</button>
        <button class="donation-modal__preset-btn" data-amount="250">$250</button>
        <button class="donation-modal__preset-btn" data-amount="500">$500</button>
      </div>

      <div class="donation-modal__custom-amount">
        <label class="donation-modal__label" for="customDonationAmount">Custom Amount</label>
        <div class="donation-modal__input-wrapper">
          <span class="donation-modal__currency">$</span>
          <input 
            type="number" 
            id="customDonationAmount" 
            class="donation-modal__input" 
            placeholder="Enter amount" 
            min="1" 
            step="0.01"
            max="999999"
          >
        </div>
        <p class="donation-modal__hint">Minimum donation: $1.00</p>
      </div>

      <div class="donation-modal__fee-info" id="donationFeeInfo" style="display: none;">
        <div class="donation-modal__fee-row">
          <span>Your donation</span>
          <span id="feeGrossAmount">$0.00</span>
        </div>
        <div class="donation-modal__fee-row">
          <span>Processing fee <small>(2.9% + $0.30)</small></span>
          <span id="feeProcessingFee">$0.00</span>
        </div>
        <div class="donation-modal__fee-row donation-modal__fee-row--total">
          <span>Campaign receives</span>
          <span id="feeNetAmount">$0.00</span>
        </div>
      </div>

      <div class="donation-modal__error" id="donationStep1Error" style="display: none;"></div>

      <button class="donation-modal__btn donation-modal__btn--primary" id="donationContinueBtn" disabled>
        Continue to Payment
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </div>

    <!-- Step 2: Payment Details (Stripe Elements) -->
    <div class="donation-modal__step" id="donationStep2" style="display: none;">
      <div class="donation-modal__summary">
        <span>Donating</span>
        <strong id="donationSummaryAmount">$0.00</strong>
        <span>to</span>
        <strong id="donationSummaryCampaign"><%= fundraiserData.title || 'this campaign' %></strong>
      </div>

      <div class="donation-modal__payment-form">
        <label class="donation-modal__label">Card Information</label>
        <div id="stripeCardElement" class="donation-modal__card-element">
          <!-- Stripe Elements will mount here -->
          <div class="donation-modal__card-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
              <line x1="1" y1="10" x2="23" y2="10"></line>
            </svg>
            <span>Loading secure payment form...</span>
          </div>
        </div>
        <div id="stripeCardErrors" class="donation-modal__card-errors"></div>

        <label class="donation-modal__label" for="donorName">Name on Card</label>
        <input type="text" id="donorName" class="donation-modal__input donation-modal__input--full" placeholder="Full name">

        <!-- Optional message -->
        <label class="donation-modal__label" for="donationMessage">Message (optional)</label>
        <textarea id="donationMessage" class="donation-modal__textarea" placeholder="Leave a message of support..." maxlength="200"></textarea>
        <p class="donation-modal__char-count"><span id="donationCharCount">0</span>/200</p>
      </div>

      <div class="donation-modal__error" id="donationStep2Error" style="display: none;"></div>

      <div class="donation-modal__btn-group">
        <button class="donation-modal__btn donation-modal__btn--secondary" id="donationBackBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back
        </button>
        <button class="donation-modal__btn donation-modal__btn--primary" id="donationSubmitBtn">
          <span class="donation-modal__btn-text">Donate Now</span>
          <span class="donation-modal__btn-loading" style="display: none;">
            <span class="donation-modal__spinner"></span>
            Processing...
          </span>
        </button>
      </div>

      <div class="donation-modal__secure">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        <span>Secure payment powered by Stripe. Your card details are encrypted.</span>
      </div>
    </div>

    <!-- Step 3: Success -->
    <div class="donation-modal__step" id="donationStep3" style="display: none;">
      <div class="donation-modal__result donation-modal__result--success">
        <div class="donation-modal__result-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
        </div>
        <h3 class="donation-modal__result-title">Thank You!</h3>
        <p class="donation-modal__result-message">
          Your donation of <strong id="successDonationAmount">$0.00</strong> has been received successfully.
        </p>
        <p class="donation-modal__result-detail">
          A confirmation receipt has been sent to your email. Your generosity makes a real impact.
        </p>
        <div class="donation-modal__result-actions">
          <button class="donation-modal__btn donation-modal__btn--primary" id="donationSuccessClose">
            Close
          </button>
        </div>
      </div>
    </div>

    <!-- Step 4: Failure -->
    <div class="donation-modal__step" id="donationStep4" style="display: none;">
      <div class="donation-modal__result donation-modal__result--error">
        <div class="donation-modal__result-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
          </svg>
        </div>
        <h3 class="donation-modal__result-title">Payment Failed</h3>
        <p class="donation-modal__result-message" id="donationFailureMessage">
          We couldn't process your payment. Please try again or use a different payment method.
        </p>
        <div class="donation-modal__result-actions">
          <button class="donation-modal__btn donation-modal__btn--secondary" id="donationRetryBtn">
            Try Again
          </button>
          <button class="donation-modal__btn donation-modal__btn--outline" id="donationFailClose">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Donation Modal Styles -->
<style>
/* ── Modal Overlay ────────────────────────────────────────────────────────── */
.donation-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  animation: donationFadeIn 0.25s ease-out;
}

@keyframes donationFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ── Modal Container ──────────────────────────────────────────────────────── */
.donation-modal {
  background: #fff;
  border-radius: 16px;
  width: 100%;
  max-width: 480px;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  animation: donationSlideUp 0.3s ease-out;
}

@keyframes donationSlideUp {
  from { transform: translateY(30px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* ── Close Button ─────────────────────────────────────────────────────────── */
.donation-modal__close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: #f5f5f5;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.2s;
  z-index: 10;
}
.donation-modal__close:hover {
  background: #e0e0e0;
  transform: rotate(90deg);
}

/* ── Header ───────────────────────────────────────────────────────────────── */
.donation-modal__header {
  padding: 32px 32px 20px;
  text-align: center;
  border-bottom: 1px solid #f0f0f0;
}
.donation-modal__icon {
  margin-bottom: 12px;
}
.donation-modal__title {
  font-size: 22px;
  font-weight: 700;
  color: #14213d;
  margin: 0 0 6px;
}
.donation-modal__subtitle {
  font-size: 14px;
  color: #767676;
  margin: 0;
}

/* ── Steps ────────────────────────────────────────────────────────────────── */
.donation-modal__step {
  padding: 24px 32px 32px;
}

/* ── Amount Presets ───────────────────────────────────────────────────────── */
.donation-modal__amount-presets {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}
.donation-modal__preset-btn {
  padding: 14px 8px;
  border: 2px solid #e8e8e8;
  border-radius: 10px;
  background: #fff;
  font-size: 16px;
  font-weight: 600;
  color: #14213d;
  cursor: pointer;
  transition: all 0.2s;
}
.donation-modal__preset-btn:hover {
  border-color: #ff9a17;
  color: #ff9a17;
}
.donation-modal__preset-btn--selected {
  border-color: #ff9a17;
  background: #fff8f0;
  color: #ff9a17;
}

/* ── Custom Amount ────────────────────────────────────────────────────────── */
.donation-modal__custom-amount {
  margin-bottom: 16px;
}
.donation-modal__label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #555;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.donation-modal__input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}
.donation-modal__currency {
  position: absolute;
  left: 14px;
  font-size: 18px;
  font-weight: 600;
  color: #999;
  pointer-events: none;
}
.donation-modal__input {
  width: 100%;
  padding: 12px 14px 12px 32px;
  border: 2px solid #e8e8e8;
  border-radius: 10px;
  font-size: 16px;
  color: #14213d;
  transition: border-color 0.2s;
  outline: none;
}
.donation-modal__input:focus {
  border-color: #ff9a17;
}
.donation-modal__input--full {
  padding-left: 14px;
}
.donation-modal__hint {
  font-size: 12px;
  color: #999;
  margin: 6px 0 0;
}

/* ── Fee Info ─────────────────────────────────────────────────────────────── */
.donation-modal__fee-info {
  background: #f8f9fa;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 20px;
}
.donation-modal__fee-row {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}
.donation-modal__fee-row--total {
  border-top: 1px solid #e0e0e0;
  padding-top: 8px;
  margin-top: 8px;
  font-weight: 600;
  color: #14213d;
}
.donation-modal__fee-row--total span:last-child {
  color: #27ae60;
}

/* ── Payment Form ─────────────────────────────────────────────────────────── */
.donation-modal__summary {
  background: #fff8f0;
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 20px;
  font-size: 14px;
  color: #555;
  text-align: center;
}
.donation-modal__summary strong {
  color: #ff9a17;
  font-weight: 700;
}
.donation-modal__card-element {
  border: 2px solid #e8e8e8;
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 8px;
  min-height: 48px;
  transition: border-color 0.2s;
}
.donation-modal__card-element--focus {
  border-color: #ff9a17;
}
.donation-modal__card-placeholder {
  display: flex;
  align-items: center;
  gap: 10px;
  color: #999;
  font-size: 14px;
}
.donation-modal__card-errors {
  font-size: 13px;
  color: #e74c3c;
  margin-bottom: 12px;
  min-height: 18px;
}
.donation-modal__textarea {
  width: 100%;
  padding: 12px 14px;
  border: 2px solid #e8e8e8;
  border-radius: 10px;
  font-size: 14px;
  color: #14213d;
  resize: vertical;
  min-height: 80px;
  transition: border-color 0.2s;
  outline: none;
  font-family: inherit;
}
.donation-modal__textarea:focus {
  border-color: #ff9a17;
}
.donation-modal__char-count {
  text-align: right;
  font-size: 12px;
  color: #999;
  margin: 4px 0 16px;
}

/* ── Buttons ──────────────────────────────────────────────────────────────── */
.donation-modal__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 24px;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  border: none;
  width: 100%;
}
.donation-modal__btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.donation-modal__btn--primary {
  background: #ff9a17;
  color: #fff;
}
.donation-modal__btn--primary:hover:not(:disabled) {
  background: #e88b14;
  transform: translateY(-1px);
}
.donation-modal__btn--secondary {
  background: #f0f0f0;
  color: #555;
}
.donation-modal__btn--secondary:hover {
  background: #e0e0e0;
}
.donation-modal__btn--outline {
  background: transparent;
  color: #999;
  border: 1px solid #e0e0e0;
}
.donation-modal__btn--outline:hover {
  border-color: #999;
  color: #666;
}
.donation-modal__btn-group {
  display: flex;
  gap: 10px;
  margin-top: 20px;
}
.donation-modal__btn-group .donation-modal__btn {
  flex: 1;
}

/* ── Loading Spinner ──────────────────────────────────────────────────────── */
.donation-modal__spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: donationSpin 0.8s linear infinite;
}
@keyframes donationSpin {
  to { transform: rotate(360deg); }
}

/* ── Error Messages ───────────────────────────────────────────────────────── */
.donation-modal__error {
  background: #ffebee;
  border: 1px solid #f5c6cb;
  border-radius: 8px;
  padding: 12px 16px;
  margin-bottom: 16px;
  font-size: 13px;
  color: #c62828;
}

/* ── Secure Badge ─────────────────────────────────────────────────────────── */
.donation-modal__secure {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
  font-size: 12px;
  color: #999;
}

/* ── Result Steps (Success/Error) ─────────────────────────────────────────── */
.donation-modal__result {
  text-align: center;
  padding: 20px 0;
}
.donation-modal__result-icon {
  margin-bottom: 16px;
}
.donation-modal__result-title {
  font-size: 20px;
  font-weight: 700;
  margin: 0 0 10px;
}
.donation-modal__result--success .donation-modal__result-title {
  color: #27ae60;
}
.donation-modal__result--error .donation-modal__result-title {
  color: #e74c3c;
}
.donation-modal__result-message {
  font-size: 14px;
  color: #555;
  line-height: 1.6;
  margin: 0 0 8px;
}
.donation-modal__result-detail {
  font-size: 13px;
  color: #999;
  margin: 0 0 24px;
}
.donation-modal__result-actions {
  display: flex;
  gap: 10px;
  justify-content: center;
}
.donation-modal__result-actions .donation-modal__btn {
  width: auto;
  min-width: 120px;
}

/* ── Responsive ───────────────────────────────────────────────────────────── */
@media (max-width: 480px) {
  .donation-modal-overlay {
    padding: 0;
    align-items: flex-end;
  }
  .donation-modal {
    max-height: 95vh;
    border-radius: 16px 16px 0 0;
  }
  .donation-modal__step {
    padding: 20px 20px 24px;
  }
  .donation-modal__header {
    padding: 24px 20px 16px;
  }
}
</style>
