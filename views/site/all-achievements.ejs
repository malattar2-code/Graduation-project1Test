<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title data-i18n="">Najdah - All Achievements</title>
  <!-- Owl Carousel -->
  <link rel="stylesheet" href="/assets/css/owl.carousel.min.css">
  <link rel="stylesheet" href="/assets/css/owl.theme.default.min.css">
  <!-- my fotawesome -->
  <link rel="stylesheet" href="/assets/css/font-awesome.min.css">
  <!-- my style css -->
  <link rel="stylesheet" href="/assets/css/style.scss">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="icon" type="image/png" href="/assets/image/Home-Page/header/najdah-icon.png">
</head>
<body>
  <!-- Start Header -->
  <header class="all-fundraisers-header-sec all-achievements-header-sec" id="header-sec">
    <!-- Start Overlay -->
    <div class="overlay"></div>
    <!-- End Overlay -->
    <!-- Start Access Links -->
    <div class="access-links">
      <div class="brand-and-help-btn">
        <!-- Start Logo -->
        <a href="/" class="brand">
          <img src="/assets/image/Home-Page/header/najdah.png" alt="">
        </a>
        <!-- End Logo -->
      </div>
      <div class="split-line"></div>
      <!-- Start Links -->
      <ul class="links">
        <li class="link-content-one active-li">
          <a class="li-btn-one li-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-clock-fill" viewBox="0 0 16 16">
              <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/>
            </svg>
            <h3 data-i18n="allAchievementsLinkOneTgt">Latest Achievements</h3>
          </a>
        </li>
        <li class="link-content-two">
          <a class="li-btn-two li-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-flag-fill" viewBox="0 0 16 16">
              <path d="M14.778.085A.5.5 0 0 1 15 .5V8a.5.5 0 0 1-.314.464L14.5 8l.186.464-.003.001-.006.003-.023.009a12 12 0 0 1-.397.15c-.264.095-.631.223-1.047.35-.816.252-1.879.523-2.71.523-.847 0-1.548-.28-2.158-.525l-.028-.01C7.68 8.71 7.14 8.5 6.5 8.5c-.7 0-1.638.23-2.437.477A20 20 0 0 0 3 9.342V15.5a.5.5 0 0 1-1 0V.5a.5.5 0 0 1 1 0v.282c.226-.079.496-.17.79-.26C4.606.272 5.67 0 6.5 0c.84 0 1.524.277 2.121.519l.043.018C9.286.788 9.828 1 10.5 1c.7 0 1.638-.23 2.437-.477a20 20 0 0 0 1.349-.476l.019-.007.004-.002h.001"/>
            </svg>
            <h3 data-i18n="allAchievementsLinkTwoTgt">Milestone Achievements</h3>
          </a>
        </li>
        <li class="link-content-three">
          <a class="li-btn-three li-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-trophy-fill" viewBox="0 0 16 16">
              <path d="M2.5.5A.5.5 0 0 1 3 0h10a.5.5 0 0 1 .5.5q0 .807-.034 1.536a3 3 0 1 1-1.133 5.89c-.79 1.865-1.878 2.917-3.167 3.037C9.19 11.693 8.477 12 8 12s-1.19-.307-2.166-.529C4.545 11.351 3.456 10.299 2.666 8.434a3 3 0 1 1-1.133-5.89Q1.5 2.239 1.5 1.5zm2.445 4.844-.125.65q.386.24.804.415c.526.208 1.1.344 1.666.344s1.14-.136 1.666-.344c.304-.12.59-.258.804-.415l-.125-.65a2 2 0 0 0-.17-.72 6 6 0 0 0-1.25-2.33c-.392-.492-.94-.995-1.703-.995-.763 0-1.311.503-1.703.995a6 6 0 0 0-1.25 2.33 2 2 0 0 0-.17.72"/>
            </svg>
            <h3 data-i18n="allAchievementsLinkThreeTgt">Final Achievements</h3>
          </a>
        </li>
        <li class="link-content-four">
          <a class="li-btn-four li-btn" href="/all-fundraisers">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-arrow-left-circle-fill" viewBox="0 0 16 16">
              <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0m3.5 7.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5z"/>
            </svg>
            <h3 data-i18n="allAchievementsLinkFourTgt">Back to Fundraisers</h3>
          </a>
        </li>
      </ul>
      <!-- End Links -->
    </div>
    <!-- End Access Links -->
    <!-- Start Main Content -->
    <div class="main-content-all-fundraisers main-content-all-achievements">
      <!-- Start All Achievements Nav -->
      <div class="all-fundraisers-nav all-achievements-nav">
        <div class="access-links-btn-box">
          <a class="access-links-btn btn-website">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-caret-right" viewBox="0 0 16 16">
              <path d="M6 12.796V3.204L11.481 8zm.659.753 5.48-4.796a1 1 0 0 0 0-1.506L6.66 2.451C6.011 1.885 5 2.345 5 3.204v9.592a1 1 0 0 0 1.659.753"/>
            </svg>
          </a>
        </div>
        <div class="search-filed-and-list-btn">
          <!-- Search Container -->
          <div class="search-container">
            <form action="/all-achievements" method="get" class="search-field" id="searchForm">
              <input type="text"
                    id="search-input"
                    name="search"
                    value="<%= searchQuery %>"
                    placeholder="Search achievements by title, description, or fundraiser..."
                    autocomplete="off">
              <button type="submit" class="search-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                  <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                </svg>
              </button>
            </form>
          </div>
          <div class="links-list-btn-box">
            <a class="links-list-btn btn-website" id="menuButton">
              <img src="/assets/image/Home-Page/header/menus.png" alt="">
            </a>
          </div>
          <!-- Start Dropdown Access Menu -->
          <div class="dropdown-content" id="dropdownMenu">
            <a href="/" data-i18n="dropdownHomeTgt">Home</a>
            <a href="/userPanelIndigent" data-i18n="dropdownDashboardTgt" id="controlPanelBtn">Dashboard</a>
            <a href="/all-fundraisers" data-i18n="dropdownFundraisersTgt">Fundraisers</a>
            <a href="/all-achievements" data-i18n="dropdownAchievementsTgt">Achievements</a>
            <a href="/categories" data-i18n="dropdownCategoriesTgt">Categories</a>
            <a href="/faq" data-i18n="dropdownContactTgt">Contact Us</a>
            <a class="language-menu" id="languageMenu" data-i18n="dropdownLanguageTgt">Language</a>
            <div class="language-switcher" id="languageSwitcher">
              <button class="lang-btn active" id="en-btn">English</button>
              <button class="lang-btn" id="ar-btn">العربية</button>
            </div>
          </div>
          <!-- End Dropdown Access Menu -->
        </div>
      </div>
      <!-- End All Achievements Nav -->

      <!-- ════════════════════════════════════════════════════════════
           SEARCH RESULTS CONTENT BOX (shown when searching)
           ════════════════════════════════════════════════════════════ -->
      <div class="content-box search-results-content-box"
          style="display: <%= (searchQuery && searchQuery.length > 0) ? 'block' : 'none' %>;">
        <% if (allAchievements && allAchievements.length > 0) { %>
          <div class="fundraisers-boxes achievements-boxes" id="searchResultsContainer">
            <% allAchievements.forEach(function(achievement) { %>
              <%- include('partials/achievement-box', { achievement: achievement }) %>
            <% }); %>
          </div>
        <% } else if (searchQuery) { %>
          <div class="no-results">
            <h3 data-i18n="allAchievementsNoResultTitleSearchTgt">No Results Found</h3>
            <p data-i18n="allAchievementsNoResultDesSearchTgt">No achievements match your search. Try different keywords.</p>
          </div>
        <% } %>
      </div>
      <!-- End Search Results Content Box -->

      <!-- ════════════════════════════════════════════════════════════
           LATEST ACHIEVEMENTS CONTENT BOX
           ════════════════════════════════════════════════════════════ -->
      <div class="content-box lastest-achievements-content-box" style="display: <%= (!searchQuery) ? 'block' : 'none' %>;">
        <% if (latestAchievements && latestAchievements.length > 0) { %>
          <div class="fundraisers-boxes achievements-boxes" id="latestAchievementsContainer">
            <% latestAchievements.forEach(function(achievement) { %>
              <%- include('partials/achievement-box', { achievement: achievement }) %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-results">
            <h3 data-i18n="allAchievementsNoResultTitleLatestTgt">No Achievements Yet</h3>
            <p data-i18n="allAchievementsNoResultDesLatestTgt">Check back later for campaign achievements.</p>
          </div>
        <% } %>
      </div>
      <!-- End Latest Achievements Content Box -->

      <!-- ════════════════════════════════════════════════════════════
           MILESTONE ACHIEVEMENTS CONTENT BOX
           ════════════════════════════════════════════════════════════ -->
      <div class="content-box milestone-achievements-content-box" style="display: <%= (!searchQuery) ? 'block' : 'none' %>;">
        <% if (milestoneAchievements && milestoneAchievements.length > 0) { %>
          <div class="fundraisers-boxes achievements-boxes" id="milestoneAchievementsContainer">
            <% milestoneAchievements.forEach(function(achievement) { %>
              <%- include('partials/achievement-box', { achievement: achievement }) %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-results">
            <h3 data-i18n="allAchievementsNoResultTitleMilestoneTgt">No Milestone Achievements</h3>
            <p data-i18n="allAchievementsNoResultDesMilestoneTgt">No milestone achievements have been posted yet.</p>
          </div>
        <% } %>
      </div>
      <!-- End Milestone Achievements Content Box -->

      <!-- ════════════════════════════════════════════════════════════
           FINAL ACHIEVEMENTS CONTENT BOX
           ════════════════════════════════════════════════════════════ -->
      <div class="content-box final-achievements-content-box" style="display: <%= (!searchQuery) ? 'block' : 'none' %>;">
        <% if (finalAchievements && finalAchievements.length > 0) { %>
          <div class="fundraisers-boxes achievements-boxes" id="finalAchievementsContainer">
            <% finalAchievements.forEach(function(achievement) { %>
              <%- include('partials/achievement-box', { achievement: achievement }) %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-results">
            <h3 data-i18n="allAchievementsNoResultTitleFinalTgt">No Final Achievements</h3>
            <p data-i18n="allAchievementsNoResultDesFinalTgt">No campaigns have reached their final achievement yet.</p>
          </div>
        <% } %>
      </div>
      <!-- End Final Achievements Content Box -->

    </div>
    <!-- End Main Content -->
  </header>
  <!-- End Header -->

  <!-- Start Footer Section -->
  <footer class="footer-sec all-fundraiser-footer">
    <div class="copyright-box">
      <ul class="copyright-box-list">
        <li><a href="#">Terms &amp; Conditions</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li>&copy; 2025 Copyright Nowrap Inc.</li>
      </ul>
    </div>
  </footer>
  <!-- End Footer Section -->

  <!-- Jquery -->
  <script src="/assets/js/jquery.js"></script>
  <!-- Owl Carousel js -->
  <script src="/assets/js/owl.carousel.min.js"></script>
  <!-- i18next -->
  <script src="/assets/libs/i18next.min.js"></script>
  <script src="/assets/libs/i18nextHttpBackend.js"></script>
  <script src="/assets/libs/i18nextBrowserLanguageDetector.js"></script>
  <!-- Custom JS -->
  <script src="/assets/js/all-achievements.js"></script>
  <!-- Google Translate script -->
  <script src="/assets/js/google-translate-custom.js"></script>
</body>
</html>
