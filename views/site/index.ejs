<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Najdah - Home</title>
  <!-- Your existing CSS links -->
  <link rel="stylesheet" href="/assets/css/owl.carousel.min.css">
  <link rel="stylesheet" href="/assets/css/owl.theme.default.min.css">
  <link rel="stylesheet" href="/assets/css/font-awesome.min.css">
  <link rel="stylesheet" href="/assets/css/style.scss">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="icon" type="image/png" href="/assets/image/Home-Page/header/najdah-icon.png">
</head>
<body>
  <!-- Start Header -->
  <header class="header-sec" id="header-sec" style="background: url('<%= banners[0] && banners[0].image ? `/uploadsBanares/${banners[0].image}` : '/assets/image/Home-Page/header/Darfur.jpg' %>') no-repeat; background-size: cover; background-position: center;">
    <!-- Start Nav -->
    <nav>
      <!-- Start Nav Links -->
      <a class="links-list btn-website" id="menuButton">
        <img src="/assets/image/Home-Page/header/menus.png" alt="Menu">
      </a>
      <!-- Start Dropdown Access Menu -->
      <div class="dropdown-content" id="dropdownMenu">
        <a href="/" data-i18n="dropdownHomeTgt">Home</a>
        <a href="/userPanelIndigent>"
           data-i18n="dropdownDashboardTgt" 
           id="controlPanelBtn">Dashboard</a>
        <a href="<%= typeof isAuthenticated !== 'undefined' && isAuthenticated ? '/all-fundraisers' : '/register' %>" 
           data-i18n="dropdownFundraisersTgt" 
           id="FundraisersDrop">Fundraisers</a>
        <a href="<%= typeof isAuthenticated !== 'undefined' && isAuthenticated ? '/categories' : '/register' %>" 
           data-i18n="dropdownCategoriesTgt" 
           id="CategoriesDrop">Categories</a>
        <a href="/all-achievements">Achievements</a>
        <a href="/faq" data-i18n="dropdownContactTgt" id="Contact_UsDrop">Contact Us</a>
        <a class="language-menu" id="languageMenu" data-i18n="dropdownLanguageTgt">Language</a>
        <div class="language-switcher" id="languageSwitcher">
          <button class="lang-btn active" id="en-btn">English</button>
          <button class="lang-btn" id="ar-btn">العربية</button>
        </div>
      </div>
      <!-- End Dropdown Access Menu -->
      <!-- End Nav Links -->
      <!-- Start Logo -->
      <a href="/" class="brand">
        <img src="/assets/image/Home-Page/header/najdah.png" alt="">
      </a>
      <!-- End Logo -->
      <!-- Start Search And Contact -->
      <div class="search-and-contact">
        <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated && user && user.user_image) { %>
          <a class="account-btn btn-website" id="controlPanelBtn" href="<%= typeof isAuthenticated !== 'undefined' && isAuthenticated ? '/userPanelIndigent' : '/register' %>">
            <img src="<%= user.user_image %>" alt="User Profile" style="width: 38px; height: 38px; border-radius: 50%; object-fit: cover;">
          </a>
        <% } else { %>
          <a class="login-btn btn-website" id="controlPanelBtn" href="<%= typeof isAuthenticated !== 'undefined' && isAuthenticated ? '/userPanelIndigent' : '/register' %>">
            <i class="fa fa-sign-in" aria-hidden="true"></i>
          </a>
        <% } %>
      </div>
      <!-- End Search And Contact -->
    </nav>
    <!-- End Nav -->
    <!-- Start Main Content -->
    <div class="main-content">
      <div class="container">
      <!-- Start Disaster Description -->
      <div class="disaster-description">
        <% banners.forEach((banner, index)=> { 
            const idText = ['three', 'four', 'five', 'six'][index] || 'three';
        %>
          <h1 class="bold p-<%= idText %>" id="banner-title-<%= index %>">
            <%= banner.title %>
          </h1>
        <% }) %>
        
        <!-- Start Disaster Info -->
        <div class="disaster-info">
          <div class="time">
            <% banners.forEach((banner, index)=> { 
              const idText = ['three', 'four', 'five', 'six'][index] || 'three';
              // Date is already a formatted string from controller, or use raw value
              const dateStr = banner.date && String(banner.date).trim() !== '' 
                ? banner.date 
                : 'N/A';
            %>
              <h2 class="light p-<%= idText %>" id="banner-date-<%= index %>">
                <%= dateStr %>
              </h2>
            <% }) %>
          </div>
          <div class="split"></div>
          <div class="location">
            <% banners.forEach((banner, index)=> { 
                const idText = ['three', 'four', 'five', 'six'][index] || 'three';
            %>
              <h2 class="light p-<%= idText %>" id="banner-region-<%= index %>">
                <%= banner.region %>
              </h2>
            <% }) %>
          </div>
        </div>
        <% banners.forEach((banner, index)=> { 
            const idText = ['three', 'four', 'five', 'six'][index] || 'three';
        %>
          <div class="description-and-find-fundraisers-btn-box">

            <p class="p-<%= idText %> p-hidden" id="banner-desc-<%= index %>">
              <%= banner.description %>.
            </p>
            <% if (banner.keyword) { %>
              
              <a 
                class="btn-website p-<%= idText %> keword-hidden find-fundraisers-btn" 
                id="banner-find-btn-<%= index %>"
                href="/all-fundraisers?search=<%= encodeURIComponent(banner.keyword) %>"
              >
                Find Fundraisers
              </a>
            <% } %>
          </div>
        <% }) %>
        <div class="btns" id="buttons-container">
        </div>
      </div>
      <!-- End Disaster Description -->
        <!-- Start Carusel -->
        <div class="carousel-box carousel-box-after">
          <div class="owl-carousel">
            <!-- Start Item -->
            <% banners.forEach((banner, index)=> { 
                const idText = ['three', 'four', 'five', 'six'][index] || 'three';
            %>
              <div class="carousel-item item-<%= idText %>" id="carousel-item-<%= index %>"
                style="background: url('/uploadsBanares/<%= banner.image %>') no-repeat; background-size: cover; background-position: center;"></div>
            <% }) %>
            <!-- End Item -->
          </div>
        </div>
        <!-- End Carusel -->
      </div>
    </div>
    <!-- End Main Content -->
  </header>
  <!-- End Header -->
  <!-- Start Most Needed Section -->
  <section class="most-fundraisers-sec">
    <div class="container">
      <div class="fundraisers-main-content">
        <!-- Start Donate Window(Form) -->
        <div class="donate-window" id="donateWindow">
          <h1 data-i18n="donateWindowTitleTgt">Choose your payment method and specify the amount you intend to donate.</h1>
          <form action="" method="post">
            <div class="select-payment-method">
              <!-- Start Payment Method One -->
              <div class="payment-method-one payment-method">
                <div class="payment-method-one-info">
                  <h1>1.</h1>
                  <img src="/assets/image/Registration-Page/sign-up/visa.png" alt="">
                  <p class="card-number-info">2147-1545-1544-5656</p>
                </div>
                <div class="flex-btns">
                  <label class="checkbox-container">
                    <input type="radio" name="payment-method" checked>
                    <span class="checkmark"></span>
                  </label>
                </div>
              </div>
              <!-- End Payment Method One -->
              <!-- Start Payment Method Two -->
              <div class="payment-method-two payment-method">
                <div class="payment-method-two-info">
                  <h1>2.</h1>
                  <img class="ms-img" src="/assets/image/Registration-Page/sign-up/mastercard.png" alt="">
                  <p class="card-number-info">2147-1545-1544-5656</p>
                </div>
                <div class="flex-btns">
                  <label class="checkbox-container">
                    <input type="radio" name="payment-method">
                    <span class="checkmark"></span>
                  </label>
                </div>
              </div>
              <!-- End Payment Method Two -->
            </div>
            <div class="flex-items">
              <!-- Start Money Req Box -->
              <div class="donate-amount-box">
                <div class="donate-amount input-box">
                  <label class="label" for="" data-i18n="donateWindowAmountTgt">Amount</label>
                  <i class="fa fa-usd"></i>
                  <input type="number">
                </div>
                <div class="note">
                  <i></i>
                  <p></p>
                </div>
              </div>
              <!-- End Money Req Box -->
              <a class="confirm-donate-btn btn-website" href="" data-i18n="donateWindowConfirmBtnTgt">Confirm Donate</a>
            </div>
          </form>
        </div>
        <!-- End Donate Window(Form) -->
        <div class="title-and-more-fundraisers">
          <h1 class="title" data-i18n="mostFundraisersTitleTgt">The Most Interactions Fundraisers</h1>
          <a href="<%= typeof isAuthenticated !== 'undefined' && isAuthenticated ? `/userPanelDonor` : '/register' %>" class="more-fundraisers-btn btn-website" data-i18n="mostFundraisersMoreBtnTgt">More Fundraisers</a>
        </div>
        <!-- Start Fundraisers Boxes -->
        <div class="fundraisers-boxes">
            <!-- Start Main Fundraiser Box -->
            <% if (typeof topFundraisers !== 'undefined' && topFundraisers.length > 0) { %>
                <% const mainFundraiser = topFundraisers[0]; %>
                <div class="main-fundraiser-box" data-fundraiser-id="<%= mainFundraiser.public_id %>" style="background: url('<%= mainFundraiser.main_image %>'); background-size: cover; background-position: center;"
                  onclick="window.location.href='/fundraiser/<%= mainFundraiser.public_id %>'">
                    <div class="fundraiser-account" onclick="handleFundraiserAccountClick(event, '<%= mainFundraiser.user.id %>')" style="cursor: pointer;">
                      <img src="<%= mainFundraiser.user.user_image %>" alt="<%= mainFundraiser.user.full_name %>">
                      <h1 class="account-name"><%= mainFundraiser.user.full_name %></h1>
                      <div class="fundraiser-Icons">
                        <% if (mainFundraiser.status !== 'waiting_verification') { %>
                          <span class="icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                              <defs>
                                <linearGradient id="verifiedGrad-main" x1="0%" y1="0%" x2="100%" y2="100%">
                                  <stop offset="0%" style="stop-color:#ff9a17;stop-opacity:1" />
                                  <stop offset="100%" style="stop-color:#e67e00;stop-opacity:1" />
                                </linearGradient>
                                <filter id="glow-main" x="-50%" y="-50%" width="200%" height="200%">
                                  <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                  <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                                </filter>
                              </defs>
                              <circle cx="12" cy="12" r="11" fill="url(#verifiedGrad-main)" stroke="#fff" stroke-width="0.8">
                                <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                              </circle>
                              <path d="M7 12l3 3 7-7" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="20" stroke-dashoffset="20" filter="url(#glow-main)">
                                <animate attributeName="stroke-dashoffset" values="20;0;0;20" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                <animate attributeName="stroke-width" values="2.5;3;2.5" dur="2s" repeatCount="indefinite" />
                              </path>
                              <circle cx="12" cy="12" r="11" fill="none" stroke="#ff9a17" stroke-width="0.5" opacity="0">
                                <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                              </circle>
                            </svg>
                            <span class="tooltip tooltip-verified">This campaign account is verified</span>
                          </span>
                        <% } %>
                        <% if (mainFundraiser.user.user_type === 'Charity') { %>
                          <span class="icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                              <defs>
                                <linearGradient id="charityGrad-main" x1="0%" y1="0%" x2="100%" y2="100%">
                                  <stop offset="0%" style="stop-color:#2ecc71;stop-opacity:1" />
                                  <stop offset="100%" style="stop-color:#27ae60;stop-opacity:1" />
                                </linearGradient>
                                <filter id="glow2-main" x="-50%" y="-50%" width="200%" height="200%">
                                  <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                  <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                                </filter>
                              </defs>
                              <circle cx="12" cy="12" r="11" fill="url(#charityGrad-main)" stroke="#fff" stroke-width="0.8">
                                <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                              </circle>
                              <path d="M12 15.5 C8 12, 6 9.5, 7 7 C8 5, 10 5, 12 7 C14 5, 16 5, 17 7 C18 9.5, 16 12, 12 15.5" fill="none" stroke="#ffffff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="28" stroke-dashoffset="28" filter="url(#glow2-main)">
                                <animate attributeName="stroke-dashoffset" values="28;0;0;28" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                <animate attributeName="stroke-width" values="2.2;2.7;2.2" dur="2s" repeatCount="indefinite" />
                              </path>
                              <circle cx="12" cy="12" r="11" fill="none" stroke="#2ecc71" stroke-width="0.5" opacity="0">
                                <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                              </circle>
                            </svg>
                            <span class="tooltip tooltip-charity">This campaign is for a charity</span>
                          </span>
                        <% } %>
                        <% if (mainFundraiser.is_urgent) { %>
                          <span class="icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                              <defs>
                                <linearGradient id="urgentGrad-main" x1="0%" y1="0%" x2="100%" y2="100%">
                                  <stop offset="0%" style="stop-color:#ff4757;stop-opacity:1" />
                                  <stop offset="100%" style="stop-color:#e84118;stop-opacity:1" />
                                </linearGradient>
                                <filter id="glow3-main" x="-50%" y="-50%" width="200%" height="200%">
                                  <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                  <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                                </filter>
                              </defs>
                              <circle cx="12" cy="12" r="11" fill="url(#urgentGrad-main)" stroke="#fff" stroke-width="0.8">
                                <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                              </circle>
                              <path d="M12 17 L12 6 M7 11 L12 6 L17 11" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="26" stroke-dashoffset="26" filter="url(#glow3-main)">
                                <animate attributeName="stroke-dashoffset" values="26;0;0;26" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                <animate attributeName="stroke-width" values="2.5;3;2.5" dur="2s" repeatCount="indefinite" />
                              </path>
                              <path d="M12 17 L12 6 M7 11 L12 6 L17 11" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0" filter="url(#glow3-main)">
                                <animate attributeName="opacity" values="0;0.5;0" dur="2s" repeatCount="indefinite" keyTimes="0;0.3;1" />
                                <animateTransform attributeName="transform" type="translate" values="0 2; 0 -3; 0 -4" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1" />
                              </path>
                              <path d="M12 17 L12 6 M7 11 L12 6 L17 11" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0" filter="url(#glow3-main)">
                                <animate attributeName="opacity" values="0;0.4;0" dur="2s" repeatCount="indefinite" keyTimes="0;0.3;1" begin="1s" />
                                <animateTransform attributeName="transform" type="translate" values="0 2; 0 -3; 0 -4" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1" begin="1s" />
                              </path>
                              <circle cx="12" cy="12" r="11" fill="none" stroke="#ff4757" stroke-width="0.5" opacity="0">
                                <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                              </circle>
                            </svg>
                            <span class="tooltip tooltip-urgent">This campaign urgently needs donations</span>
                          </span>
                        <% } %>
                      </div>
                    </div>
                    <div class="fundraiser-title">
                        <h2 class="main-title">
                          <%= mainFundraiser.title.length > 15 ?
                            mainFundraiser.title.substring(0, 15) + '...' :
                            mainFundraiser.title %>
                        </h2>
                        <span>
                          <%= mainFundraiser.location %>
                        </span>
                    </div>
                    <!-- Categories Display -->
                    <% if (mainFundraiser.categories && mainFundraiser.categories.length > 0) { %>
                        <div class="fundraiser-categories">
                            <% mainFundraiser.categories.forEach(function(category, index) { %>
                                <span class="category-tag"><%= category %></span>
                            <% }); %>
                        </div>
                    <% } %>
                    <p class="fundraiser-des">
                        <%= mainFundraiser.description.length > 200 ? mainFundraiser.description.substring(0, 200) + '...' : mainFundraiser.description %>
                    </p>
                    <div class="fundraiser-btns">
                        <div class="flex-btns">
                            <button class="save-fundraiser-btn donate-later-btn btn-website">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="bi bi-bookmark-plus" viewBox="0 0 16 16">
                                    <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1z"/>
                                    <path d="M8 4a.5.5 0 0 1 .5.5V6H10a.5.5 0 0 1 0 1H8.5v1.5a.5.5 0 0 1-1 0V7H6a.5.5 0 0 1 0-1h1.5V4.5A.5.5 0 0 1 8 4"/>
                                </svg>
                            </button>
                            <!-- Start Donation bar -->
                            <div class="donation-bar">
                                <div class="donation-scale">
                                    <div class="donation-progress" style="width: <%= mainFundraiser.progress_percentage %>%;"></div>
                                </div>
                                <div class="donation-money-number">
                                  <!-- AFTER -->
                                  <div class="money" data-goal="<%= mainFundraiser.target_amount %>">
                                      $<%= mainFundraiser.collected_amount.toLocaleString('en') %> / $<%= mainFundraiser.target_amount.toLocaleString('en') %>
                                  </div>
                                </div>
                            </div>
                            <!-- End Donation bar -->
                        </div>
                        <a class="main-donate-btn btn-website" id="donateBtn" href="/fundraiser/<%= mainFundraiser.public_id %>">
                            <img src="/assets/image/Home-Page/most-fundraisers/money.png" alt="Donate">
                        </a>
                    </div>
                </div>
            <% } else { %>
                <!-- Fallback if no fundraisers -->
                <div class="main-fundraiser-box" style="background: url('/assets/image/Home-Page/most-fundraisers/main-fundraiser-img.jpg');">
                    <div class="fundraiser-account">
                        <img src="/assets/image/Fundraiser-Page/header-sec/man-profile.png" alt="">
                        <h1 class="account-name">No Fundraisers Available</h1>
                    </div>
                    <div class="fundraiser-title">
                        <h2 class="main-title">Be the first to create a fundraiser</h2>
                        <span>Start making a difference today</span>
                    </div>
                    <p class="fundraiser-des">There are currently no trending fundraisers. Create the first one and help make a positive impact in your community.</p>
                    <div class="fundraiser-btns">
                        <div class="flex-btns">
                            <a href="/create-fundraiser" class="donate-btn btn-website">Create Fundraiser</a>
                        </div>
                    </div>
                </div>
            <% } %>
            <!-- End Main Fundraiser Box -->
            
            <!-- Start Sub Fundraiser Boxes -->
            <div class="sub-fundraisers-boxes">
                <% if (typeof topFundraisers !== 'undefined' && topFundraisers.length > 1) { %>
                    <% topFundraisers.slice(1, 5).forEach(function(fundraiser, index) { %>
                        <!-- Start Sub Fundraiser Box -->
                        <div class="sub-fundraiser-box" data-fundraiser-id="<%= fundraiser.public_id %>">
                            <div class="fundraiser-account" onclick="handleFundraiserAccountClick(event, '<%= fundraiser.user.id %>')" style="cursor: pointer;">
                              <img src="<%= fundraiser.user.user_image %>" alt="<%= fundraiser.user.full_name %>">
                              <h1 class="account-name"><%= fundraiser.user.full_name %></h1>
                              <div class="fundraiser-Icons">
                                <% if (fundraiser.status !== 'waiting_verification') { %>
                                  <span class="icon-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                                      <defs>
                                        <linearGradient id="verifiedGrad-<%= fundraiser.public_id %>" x1="0%" y1="0%" x2="100%" y2="100%">
                                          <stop offset="0%" style="stop-color:#ff9a17;stop-opacity:1" />
                                          <stop offset="100%" style="stop-color:#e67e00;stop-opacity:1" />
                                        </linearGradient>
                                        <filter id="glow-<%= fundraiser.public_id %>" x="-50%" y="-50%" width="200%" height="200%">
                                          <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                          <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                                        </filter>
                                      </defs>
                                      <circle cx="12" cy="12" r="11" fill="url(#verifiedGrad-<%= fundraiser.public_id %>)" stroke="#fff" stroke-width="0.8">
                                        <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                                      </circle>
                                      <path d="M7 12l3 3 7-7" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="20" stroke-dashoffset="20" filter="url(#glow-<%= fundraiser.public_id %>)">
                                        <animate attributeName="stroke-dashoffset" values="20;0;0;20" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                        <animate attributeName="stroke-width" values="2.5;3;2.5" dur="2s" repeatCount="indefinite" />
                                      </path>
                                      <circle cx="12" cy="12" r="11" fill="none" stroke="#ff9a17" stroke-width="0.5" opacity="0">
                                        <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                                      </circle>
                                    </svg>
                                    <span class="tooltip tooltip-verified">This campaign account is verified</span>
                                  </span>
                                <% } %>
                                <% if (fundraiser.user.user_type === 'Charity') { %>
                                  <span class="icon-wrapper">
