                            ✓ Form Filled Out
                          </div>
                        <% } else if (fundraiser.form_current >= fundraiser.form_target) { %>
                          <div class="money" style="color: #dc3545; font-weight: bold;">
                            ✕ Target Reached
                          </div>
                        <% } else { %>
                          <div class="money" style="color: #6f42c1; font-weight: bold;">
                            📝 Form Available (<%= fundraiser.form_current %>/<%= fundraiser.form_target %>)
                          </div>
                        <% } %>
                      </div>
                    </div>
                    
                    <!-- CONDITIONAL BUTTON -->
                    <% if (!fundraiser.user_has_submitted && fundraiser.form_current < fundraiser.form_target) { %>
                      <a class="fill-form-btn btn-website"
                         href="/fundraiser-requester-form/<%= fundraiser.public_id %>"
                         style="background: #6f42c1;">
                        Fill Form
                      </a>
                    <% } else if (fundraiser.user_has_submitted) { %>
                      <button class="fill-form-btn btn-website" 
                              style="background: #6c757d; cursor: not-allowed; opacity: 0.7;" 
                              disabled>
