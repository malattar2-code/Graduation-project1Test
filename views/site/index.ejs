                    <% } else { %>
                      <button class="fill-form-btn btn-website" 
                              style="background: #dc3545; cursor: not-allowed; opacity: 0.7;" 
                              disabled>
                        ✕ Target Reached
                      </button>
                    <% } %>
                  </div>
                </div>
              </div>
              <!-- End Charity Fundraiser Box -->
            <% }); %>
