              <!-- End Show More Button for Saved  -->
          <% } else { %>
              <div class="no-results">
                  <h3 data-i18n="allFundraisersNoResultTitleSavedTgt">No Saved Fundraisers</h3>
                  <p data-i18n="allFundraisersNoResultDesSavedTgt">Check back later for new fundraising campaigns.</p>
              </div>
          <% } %>
          <!-- End Fundraisers Boxes -->
      </div>
      <!-- End Saved Fundraisers Content Box -->
      <!-- ════════════════════════════════════════════════════════════════════════
      CHARITY FUNDRAISERS CONTENT BOX (Waiting_requesters - for requesters)
      Shows campaigns with forms ready to be filled
      - Hides campaigns that reached target (handled in backend)
      - Shows "Form Filled Out" for already-submitted campaigns
      - Disables/hides fill-form button for submitted campaigns
      ════════════════════════════════════════════════════════════════════════ -->
      <div class="content-box charity-fundraisers-content-box" style="display: <%= (!searchQuery && !categoryFilter && user && user.user_type === 'requester') ? 'block' : 'none' %>;">
          <% if (charityFundraisers && charityFundraisers.length > 0) { %>
              <div class="fundraisers-boxes" id="charityFundraisersContainer">
                  <% charityFundraisers.forEach(function(fundraiser, index) { %>
                      <div class="fundraiser-box <%= fundraiser.user_has_submitted ? 'campaign-submitted' : '' %> <%= (fundraiser.form_current >= fundraiser.form_target) ? 'campaign-full' : '' %>" 
                          data-fundraiser-id="<%= fundraiser.public_id %>">
                          
                          <!-- AFTER -->
                          <div class="fundraiser-account" data-account-link="/indigent-account/<%= fundraiser.fundraiser_user_id %>" style="cursor: pointer;">
                              <% if (fundraiser.user_image) { %>
                                  <img src="<%= fundraiser.user_image %>" 
                                      alt="<%= fundraiser.user_name %>'s Profile"
                                      onerror="this.src='/assets/image/Fundraiser-Page/header-sec/man-profile.png'">
                              <% } else { %>
                                  <img src="/assets/image/Fundraiser-Page/header-sec/man-profile.png" alt="Default Profile">
                              <% } %>
                              <h1 class="account-name"><%= fundraiser.user_name %></h1>
                              <div class="fundraiser-Icons">
                                <% if (fundraiser.fundraiser_status !== 'waiting_verification') { %>
                                  <span class="icon-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                                      <defs>
                                        <linearGradient id="verifiedGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                          <stop offset="0%" style="stop-color:#ff9a17;stop-opacity:1" />
                                          <stop offset="100%" style="stop-color:#e67e00;stop-opacity:1" />
                                        </linearGradient>
                                        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                                          <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                          <feMerge>
                                            <feMergeNode in="coloredBlur"/>
                                            <feMergeNode in="SourceGraphic"/>
                                          </feMerge>
                                        </filter>
                                      </defs>
                                      <circle cx="12" cy="12" r="11" fill="#ff9a17" stroke="#fff" stroke-width="0.8">
                                        <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                                      </circle>
                                      <path d="M7 12l3 3 7-7" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="20" stroke-dashoffset="20" filter="url(#glow)">
                                        <animate attributeName="stroke-dashoffset" values="20;0;0;20" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                        <animate attributeName="stroke-width" values="2.5;3;2.5" dur="2s" repeatCount="indefinite" />
                                      </path>
                                      <circle cx="12" cy="12" r="11" fill="none" stroke="#ff9a17" stroke-width="0.5" opacity="0">
                                        <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                                      </circle>
                                    </svg>
                                    <span class="tooltip tooltip-verified">This campaign account is verified</span>
                                  </span>
                                <% } %>

                                <% if (fundraiser.user_type === 'Charity') { %>
                                  <span class="icon-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                                      <defs>
                                        <linearGradient id="charityGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                          <stop offset="0%" style="stop-color:#2ecc71;stop-opacity:1" />
                                          <stop offset="100%" style="stop-color:#27ae60;stop-opacity:1" />
                                        </linearGradient>
                                        <filter id="glow2" x="-50%" y="-50%" width="200%" height="200%">
                                          <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                          <feMerge>
                                            <feMergeNode in="coloredBlur"/>
                                            <feMergeNode in="SourceGraphic"/>
                                          </feMerge>
                                        </filter>
                                      </defs>
                                      <circle cx="12" cy="12" r="11" fill="#2ecc71" stroke="#fff" stroke-width="0.8">
                                        <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                                      </circle>
                                      <path d="M12 15.5 C8 12, 6 9.5, 7 7 C8 5, 10 5, 12 7 C14 5, 16 5, 17 7 C18 9.5, 16 12, 12 15.5" fill="none" stroke="#ffffff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="28" stroke-dashoffset="28" filter="url(#glow2)">
                                        <animate attributeName="stroke-dashoffset" values="28;0;0;28" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                        <animate attributeName="stroke-width" values="2.2;2.7;2.2" dur="2s" repeatCount="indefinite" />
                                      </path>
                                      <circle cx="12" cy="12" r="11" fill="none" stroke="#2ecc71" stroke-width="0.5" opacity="0">
                                        <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                                      </circle>
                                    </svg>
                                    <span class="tooltip tooltip-charity">This campaign is for a charity</span>
                                  </span>
                                <% } %>

                                <% if (fundraiser.is_urgent) { %>
                                  <span class="icon-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" style="display: inline-block; vertical-align: middle;">
                                      <defs>
                                        <linearGradient id="urgentGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                          <stop offset="0%" style="stop-color:#ff4757;stop-opacity:1" />
                                          <stop offset="100%" style="stop-color:#e84118;stop-opacity:1" />
                                        </linearGradient>
                                        <filter id="glow3" x="-50%" y="-50%" width="200%" height="200%">
                                          <feGaussianBlur stdDeviation="0.6" result="coloredBlur"/>
                                          <feMerge>
                                            <feMergeNode in="coloredBlur"/>
                                            <feMergeNode in="SourceGraphic"/>
                                          </feMerge>
                                        </filter>
                                      </defs>
                                      <circle cx="12" cy="12" r="11" fill="#ff4757" stroke="#fff" stroke-width="0.8">
                                        <animate attributeName="r" values="11;11.4;11" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="1;0.92;1" dur="3s" repeatCount="indefinite" />
                                      </circle>
                                      <path d="M12 17 L12 6 M7 11 L12 6 L17 11" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="26" stroke-dashoffset="26" filter="url(#glow3)">
                                        <animate attributeName="stroke-dashoffset" values="26;0;0;26" dur="3s" repeatCount="indefinite" keyTimes="0;0.3;0.8;1" />
                                        <animate attributeName="stroke-width" values="2.5;3;2.5" dur="2s" repeatCount="indefinite" />
                                      </path>
                                      <path d="M12 17 L12 6 M7 11 L12 6 L17 11" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0" filter="url(#glow3)">
                                        <animate attributeName="opacity" values="0;0.5;0" dur="2s" repeatCount="indefinite" keyTimes="0;0.3;1" />
                                        <animateTransform attributeName="transform" type="translate" values="0 2; 0 -3; 0 -4" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1" />
                                      </path>
                                      <path d="M12 17 L12 6 M7 11 L12 6 L17 11" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0" filter="url(#glow3)">
                                        <animate attributeName="opacity" values="0;0.4;0" dur="2s" repeatCount="indefinite" keyTimes="0;0.3;1" begin="1s" />
                                        <animateTransform attributeName="transform" type="translate" values="0 2; 0 -3; 0 -4" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1" begin="1s" />
                                      </path>
                                      <circle cx="12" cy="12" r="11" fill="none" stroke="#ff4757" stroke-width="0.5" opacity="0">
                                        <animate attributeName="r" values="11;14;16" dur="2.5s" repeatCount="indefinite" />
                                        <animate attributeName="opacity" values="0.5;0;0" dur="2.5s" repeatCount="indefinite" />
                                      </circle>
                                    </svg>
                                    <span class="tooltip tooltip-urgent">This campaign urgently needs donations</span>
                                  </span>
                                <% } %>
                              </div>
                          </div>
                          
                          <div class="fundraiser-img" 
                              style="background: url('<%= fundraiser.fundraiser_main_image %>') center/cover;">
                          </div>
                          
                          <div class="fundraiser-title">
                              <h2 class="main-title">
                              <%= fundraiser.fundraiser_title.length > 15 ?
                                fundraiser.fundraiser_title.substring(0, 15) + '...' :
                                fundraiser.fundraiser_title %>
                              </h2>
                              <span><%= fundraiser.user_location %></span>
                          </div>
                          
                          <% if (fundraiser.fundraiser_categories && fundraiser.fundraiser_categories.length > 0) { %>
                              <div class="fundraiser-categories">
                                  <% fundraiser.fundraiser_categories.forEach(function(category, index) { %>
                                      <span class="category-tag"><%= category %></span>
                                  <% }); %>
                              </div>
                          <% } %>
                          
                          <p class="fundraiser-des">
                            <%= fundraiser.fundraiser_description.length > 150 ? 
                                fundraiser.fundraiser_description.substring(0, 150) + '...' : 
                                fundraiser.fundraiser_description %> 
                          </p>
                          
                          <div class="fundraiser-btns">
                              <div class="flex-btns">
                                  <!-- Progress bar showing requesters count -->
                                  <div class="donation-bar" style="background: transparent;">
                                      <div class="donation-charity-note">
                                          <% if (fundraiser.user_has_submitted) { %>
                                              <div class="money" style="color: #28a745; font-weight: bold;">
                                                  ✓ Form Filled Out
                                              </div>
                                          <% } else if (fundraiser.form_current >= fundraiser.form_target) { %>
                                              <div class="money" style="color: #dc3545; font-weight: bold;">
                                                  ✕ Target Reached
                                              </div>
                                          <% } else { %>
                                              <div class="money" style="color: #6f42c1; font-weight: bold;">
                                                  📝 Form Available (<%= fundraiser.form_current %>/<%= fundraiser.form_target %>)
                                              </div>
                                          <% } %>
                                      </div>
                                  </div>
                              </div>
                              
                              <!-- CONDITIONAL BUTTON: Hide if already submitted or full -->
                              <% if (!fundraiser.user_has_submitted && fundraiser.form_current < fundraiser.form_target) { %>
                                  <a href="/fundraiser-requester-form/<%= fundraiser.public_id %>" 
                                    class="btn-website fill-form" 
                                    style="background: #6f42c1;">
                                      Fill Form
                                  </a>
                              <% } else if (fundraiser.user_has_submitted) { %>
                                  <!-- Already submitted: show disabled state -->
                                  <button class="btn-website fill-form" 
                                          style="background: #6c757d; cursor: not-allowed; opacity: 0.7;" 
                                          disabled>
                                      ✓ Already Filled
                                  </button>
                              <% } else { %>
                                  <!-- Campaign full: show disabled state -->
                                  <button class="btn-website fill-form" 
                                          style="background: #dc3545; cursor: not-allowed; opacity: 0.7;" 
                                          disabled>
                                      ✕ Target Reached
                                  </button>
                              <% } %>
                          </div>
                      </div>
                  <% }); %>
              </div>
              
              <div class="show-more-box">
                  <% if (charityHasMore) { %>
                      <div class="pagination-controls charity-pagination" data-section="charity">
                          <button class="prev-page-btn btn-website" data-page="<%= charityCurrentPage - 1 %>" <%= charityCurrentPage <= 1 ? 'disabled' : '' %>>Previous</button>
                          <span class="page-info">Page <%= charityCurrentPage %> of <%= charityTotalPages %></span>
                          <button class="next-page-btn btn-website" data-page="<%= charityCurrentPage + 1 %>" <%= charityCurrentPage >= charityTotalPages ? 'disabled' : '' %>>Next</button>
                      </div>
                  <% } %>
              </div>
          <% } else { %>
              <div class="no-results">
                  <h3 data-i18n="allFundraisersNoResultTitleCharityTgt">No Available Campaign Forms</h3>
                  <p data-i18n="allFundraisersNoResultDesCharityTgt">No charity campaigns are currently accepting requests.</p>
              </div>
          <% } %>
      </div>
      <!-- End Charity Fundraisers Content Box -->
    </div>
    <!-- End Main Content -->
  </header>
  <!-- End Header -->
  <!-- Start Footer Section -->
  <footer class="footer-sec all-fundraiser-footer">
    <!-- Start Copyright Section -->
    <div class="copyright-box">
      <ul class="copyright-box-list">
        <li><a href="#">Terms &amp; Conditions</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li>&copy; 2025 Copyright Nowrap Inc.</li>
      </ul>
    </div>
    <!-- End Copyright Section -->
  </footer>
  <!-- End Footer Section -->
  <!-- Compiled and minified JavaScript -->
  <!-- <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script> -->
  <!-- Jquery -->
  <script src="/assets/js/jquery.js"></script>
  <!-- Owl Carousel js -->
  <script src="/assets/js/owl.carousel.min.js"></script>
  <!-- مكتبات i18next من CDN -->
  <script src="/assets/libs/i18next.min.js"></script>
  <script src="/assets/libs/i18nextHttpBackend.js"></script>
  <script src="/assets/libs/i18nextBrowserLanguageDetector.js"></script>
  <!-- Custom my js -->
  <!-- NEW: Config bridge (small, safe inline data-passing) -->
  <script>
    window.APP_CONFIG = {
      categories: <%- JSON.stringify(typeof categories !== 'undefined' ? categories : []) %>,
      searchQuery: "<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>",
      categoryFilter: "<%= typeof categoryFilter !== 'undefined' ? categoryFilter : '' %>"
    };
  </script>
  <script src="/assets/js/all-fundraisers.js"></script>
  <!-- FontAwesome Icon-->
  <!-- <script src="https://kit.fontawesome.com/6fccdcc8fe.js" crossorigin="anonymous"></script> -->
  <!-- NEW: custom Google Translate script -->
  <script src="/assets/js/google-translate-custom.js"></script>
</body> 
</html>
