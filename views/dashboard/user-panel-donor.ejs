              <h1 data-i18n="userPanelAccountChangeTitleTgt">Change Account Settings :</h1>
              <!-- Start Flex Boxes -->
              <div class="flex-boxes">
                <div class="box-one">
                  <!-- Old Password -->
                  <div class="input-box old-password">
                    <label class="label" for="oldPassword" data-i18n="userPanelAccountChangePasswordLabelTgt">Old Password</label>
                    <input type="password" id="oldPassword" name="oldPassword" maxlength="128">
                    <div class="validation-error" id="old-password-error" style="display: none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                      </svg>
                      <p class="error-message"></p>
                    </div>
                  </div>

                  <!-- New Password -->
                  <div class="input-box new-password">
                    <label class="label" for="newPassword" data-i18n="userPanelAccountChangeNewPasswordLabelTgt">New Password</label>
                    <input type="password" id="newPassword" name="newPassword" maxlength="128">
                    <div class="validation-error" id="new-password-error" style="display: none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                      </svg>
                      <p class="error-message"></p>
                    </div>
                  </div>

                  <!-- Confirm New Password -->
                  <div class="input-box confirm-new-password">
                    <label class="label" for="confirmNewPassword" data-i18n="userPanelAccountChangeConfirmNewPasswordLabelTgt">Confirm New Password</label>
                    <input type="password" id="confirmNewPassword" name="confirmNewPassword" maxlength="128">
                    <div class="validation-error" id="confirm-new-password-error" style="display: none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                      </svg>
                      <p class="error-message"></p>
                    </div>
                  </div>
                </div>
                <div class="box-two">
                  <!-- CHANGE-USER-IMAGE-BOX: Styled with user icon -->
                  <div class="change-user-image-box">
                    <div class="image-upload-wrapper">
                      <div class="upload-area" id="userImageUploadArea">
                        <input type="file" name="image" id="changeUserImage" class="image-input" accept="image/*">
                        <div class="upload-placeholder">
                          <i class="fa fa-user-circle" aria-hidden="true"></i>
                          <span class="upload-text" data-i18n="userPanelAccountChangeImageLabelTgt">Change Your Image</span>
                        </div>
                        <div class="upload-preview" id="userImagePreview" style="display: none;">
                          <img src="" alt="Preview" id="userImagePreviewImg">
                          <button type="button" class="remove-image-btn" id="removeUserImage">
                            <i class="fa fa-times"></i>
                          </button>
                        </div>
                      </div>
                      <div class="validation-error" id="change-user-image-error" style="display: none;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                          <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                        </svg>
                        <p class="error-message"></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Submit Button -->
              <div class="change-btn-box">
                <button type="submit" class="change-btn btn-website" data-i18n="userPanelAccountChangeBtnTgt">Save Changes</button>
              </div>
            </form>
            <!-- Start Change Account Setting -->
          </div>
          <!-- End Account Settings Section -->
        </div>
        <!-- End Main Content -->
      </div>
    </div>
    <!-- End Main Section -->
  </header>
  <!-- End Header -->
  <!-- Start Footer Section -->
  <footer class="footer-sec user-panel-footer">
    <!-- Start Copyright Section -->
    <div class="copyright-box">
      <ul class="copyright-box-list">
        <li><a href="#">Terms &amp; Conditions</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li>&copy; 2025 Copyright Nowrap Inc.</li>
      </ul>
    </div>
    <!-- End Copyright Section -->
  </footer>
