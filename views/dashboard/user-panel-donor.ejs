        <!-- Start Submit A Complaint Box(Form) -->
        <div class="submit-complaint" id="submitComplaint">
            <h1 data-i18n="complaintTitleTgt">Enter the problem you are facing</h1>
            <form id="complaintForm" method="post">
                <div class="title-filed input-box">
                    <label class="label-desc" for="complaint_content" data-i18n="complaintLabelTgt">Enter A Problem</label>
                    <textarea 
                        id="complaint_content" 
                        name="complaint_content" 
                        required 
                        maxlength="100"
                    ></textarea>
                    <div class="characters">
                        <span class="signal_num">0</span>
                        <span class="limit_num">/100</span>
                    </div>
                </div>
                <button type="submit" class="complaint-submit-btn btn-website" data-i18n="complaintBtnTgt">
                    Send
                </button>
            </form>
            <div id="complaintMessage" style="display: none; margin-top: 15px; padding: 10px; border-radius: 5px;"></div>
        </div>
