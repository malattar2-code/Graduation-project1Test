  <script src="/assets/js/jquery.js"></script>
  <!-- Owl Carousel js -->
  <script src="/assets/js/owl.carousel.min.js"></script>
  <!-- مكتبات i18next من CDN -->
  <script src="/assets/libs/i18next.min.js"></script>
  <script src="/assets/libs/i18nextHttpBackend.js"></script>
  <script src="/assets/libs/i18nextBrowserLanguageDetector.js"></script>
  <!-- My Custom js -->
  <!-- Add this hidden element to pass server-side data -->
  <% 
    // Compute currentRank once for reuse
    const currentRank = ranks && userRankData && userRankData.currentRankId 
      ? ranks.find(r => r.rank_id === userRankData.currentRankId) 
      : null;
  %>
    <div id="server-data" 
      data-user-points="<%= userRankData && userRankData.userPoints ? userRankData.userPoints : 0 %>"
      data-rank-name="<%= userRankData && userRankData.rankName ? userRankData.rankName : '' %>"
      data-rank-image="<%= userRankData && userRankData.rankImage ? userRankData.rankImage : '' %>"
      data-reward-image="<%= userRankData && userRankData.rewardImage ? userRankData.rewardImage : '' %>"
      data-reward-name="<%= userRankData && userRankData.rewardName ? userRankData.rewardName : '' %>"
      style="display: none;">
  </div>
