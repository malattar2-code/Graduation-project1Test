                          <!-- Display user points from EJS data or default -->
                          <span class="metric-rank-value user-points" id="rank-value">
                            <%= userRankData && userRankData.userPoints ? userRankData.userPoints : 0 %>
                          </span>
                        </div>
                        <div class="progress-container">
                          <div class="progress-bar rank-bar" id="rank-bar" 
                              style="width: <%= userRankData && userRankData.userPoints ? (function() {
                                const points = userRankData.userPoints;
                                if (points <= 0) return 0;
                                if (points >= 10000) return 100;
                                const scale = [
                                  { points: 0, percent: 0 },
                                  { points: 100, percent: 10 },
                                  { points: 500, percent: 15 },
                                  { points: 1000, percent: 20 },
                                  { points: 5000, percent: 60 },
                                  { points: 10000, percent: 100 }
                                ];
                                for (let i = 1; i < scale.length; i++) {
                                  if (points <= scale[i].points) {
                                    const prev = scale[i-1];
                                    const curr = scale[i];
                                    const segmentPoints = curr.points - prev.points;
                                    const segmentPercent = curr.percent - prev.percent;
                                    const pointsInSegment = points - prev.points;
                                    return prev.percent + (pointsInSegment / segmentPoints) * segmentPercent;
                                  }
                                }
                                return 100;
                              })() : 0 %>%;"></div>
                        </div>
                        <div class="point-scale">
