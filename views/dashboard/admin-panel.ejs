  <!-- TRANSFER EXECUTION MODAL -->
  <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
  <div id="transferModal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 10000; align-items: center; justify-content: center;">
    <div class="modal-content" style="background: #fff; border-radius: 12px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.3);">
      
      <!-- Header -->
      <div class="modal-header" style="padding: 20px 24px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center;">
        <h3 style="margin: 0; font-size: 18px; font-weight: 600; color: #1f2937;">
          <span id="transferModalStep">Step 1 of 2</span> — Execute Transfer
        </h3>
        <button onclick="closeTransferModal()" style="background: none; border: none; font-size: 24px; cursor: pointer; color: #6b7280;">&times;</button>
      </div>

      <!-- Body -->
      <div class="modal-body" style="padding: 24px;">
        
        <!-- Transfer Info Summary -->
        <div class="transfer-info" style="background: #f3f4f6; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
            <span style="color: #6b7280; font-size: 13px;">Withdraw Request ID</span>
            <span id="transferWithdrawId" style="font-weight: 600; font-size: 13px;">-</span>
          </div>
          <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
            <span style="color: #6b7280; font-size: 13px;">Amount to Transfer</span>
            <span id="transferAmount" style="font-weight: 600; font-size: 13px; color: #059669;">-</span>
          </div>
          <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
            <span style="color: #6b7280; font-size: 13px;">Platform Fee (3%)</span>
            <span id="transferFee" style="font-weight: 600; font-size: 13px; color: #dc2626;">-</span>
          </div>
          <div style="display: flex; justify-content: space-between; padding-top: 8px; border-top: 1px solid #d1d5db;">
            <span style="color: #374151; font-weight: 600; font-size: 14px;">Net Amount</span>
            <span id="transferNetAmount" style="font-weight: 700; font-size: 14px; color: #059669;">-</span>
          </div>
          <div style="display: flex; justify-content: space-between; margin-top: 8px;">
            <span style="color: #6b7280; font-size: 13px;">User Requested Method</span>
            <span id="transferMethod" style="font-weight: 600; font-size: 13px;">-</span>
          </div>
        </div>

        <!-- Step 1: Review Recipient Information -->
        <div id="transferStep1">
          <h4 style="margin: 0 0 16px 0; font-size: 15px; color: #374151; font-weight: 600;">
            <span style="display: inline-block; width: 24px; height: 24px; background: #ff9a17; color: white; border-radius: 50%; text-align: center; line-height: 24px; font-size: 12px; margin-right: 8px;">1</span>
            Review Recipient Information
          </h4>
          <p style="font-size: 12px; color: #6b7280; margin-bottom: 16px;">These details were provided by the user in their withdrawal request.</p>
          
          <div id="recipientDetailsContainer" style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px;">
            <!-- Dynamically populated -->
          </div>
        </div>

        <!-- Step 2: Platform Transfer Configuration -->
        <div id="transferStep2" style="display: none;">
          <h4 style="margin: 0 0 16px 0; font-size: 15px; color: #374151; font-weight: 600;">
            <span style="display: inline-block; width: 24px; height: 24px; background: #ff9a17; color: white; border-radius: 50%; text-align: center; line-height: 24px; font-size: 12px; margin-right: 8px;">2</span>
            Platform Transfer Configuration
          </h4>
          
          <!-- Transfer Method Selector -->
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 8px;">Select Transfer Method <span style="color: #dc2626;">*</span></label>
            <p style="font-size: 11px; color: #6b7280; margin-bottom: 10px;">Choose how YOU (the platform) will send the funds. This can be different from what the user requested.</p>
            
            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
              <button type="button" class="transfer-method-tab" data-method="stripe" onclick="updatePlatformFormVisibility('stripe')" 
                style="padding: 10px 16px; border: 2px solid #d1d5db; background: #f3f4f6; color: #374151; border-radius: 8px; font-size: 13px; cursor: pointer; font-weight: 600; transition: all 0.2s;">
                💳 Stripe
              </button>
              <button type="button" class="transfer-method-tab" data-method="bank_transfer" onclick="updatePlatformFormVisibility('bank_transfer')" 
                style="padding: 10px 16px; border: 2px solid #d1d5db; background: #f3f4f6; color: #374151; border-radius: 8px; font-size: 13px; cursor: pointer; font-weight: 600; transition: all 0.2s;">
                🏦 Bank Transfer
              </button>
              <button type="button" class="transfer-method-tab" data-method="paypal" onclick="updatePlatformFormVisibility('paypal')" 
                style="padding: 10px 16px; border: 2px solid #d1d5db; background: #f3f4f6; color: #374151; border-radius: 8px; font-size: 13px; cursor: pointer; font-weight: 600; transition: all 0.2s;">
                🅿️ PayPal
              </button>
              <button type="button" class="transfer-method-tab" data-method="palpay" onclick="updatePlatformFormVisibility('palpay')" 
                style="padding: 10px 16px; border: 2px solid #d1d5db; background: #f3f4f6; color: #374151; border-radius: 8px; font-size: 13px; cursor: pointer; font-weight: 600; transition: all 0.2s;">
                📱 PalPay
              </button>
            </div>
          </div>

          <!-- Platform Account Forms -->
          
          <!-- Stripe Platform Account -->
          <div id="platformStripe" style="display: none;">
            <div style="background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 8px; padding: 12px; margin-bottom: 16px;">
              <p style="margin: 0; font-size: 12px; color: #059669; font-weight: 500;">✅ Stripe is fully supported. Funds will be transferred from your platform account to the connected account.</p>
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Your Platform Stripe Account ID</label>
              <input type="text" id="platformStripeAccountId" placeholder="acct_xxxxxxxxxxxxxx" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
              <p style="font-size: 11px; color: #6b7280; margin-top: 4px;">Your platform's Stripe Connect account ID (the source of funds).</p>
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Stripe Secret Key (optional)</label>
              <input type="password" id="platformStripeKey" placeholder="sk_live_..." 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
              <p style="font-size: 11px; color: #6b7280; margin-top: 4px;">Leave empty to use server-configured STRIPE_SECRET_KEY.</p>
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Recipient Connected Account ID</label>
              <input type="text" id="recipientStripeAccountId" placeholder="acct_xxxxxxxxxxxxxx" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box; background: #f9fafb;">
              <p style="font-size: 11px; color: #6b7280; margin-top: 4px;">The user's Stripe connected account (auto-filled from request if available).</p>
            </div>
          </div>

          <!-- Bank Transfer Platform -->
          <div id="platformBank" style="display: none;">
            <div style="background: #fef3c7; border: 1px solid #fcd34d; border-radius: 8px; padding: 12px; margin-bottom: 16px;">
              <p style="margin: 0; font-size: 12px; color: #d97706; font-weight: 500;">⚠️ Bank Transfer is not yet fully automated. You will need to manually complete the transfer through your bank portal.</p>
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Platform Bank Account Number</label>
              <input type="text" id="platformBankAccount" placeholder="Enter your platform account number" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Platform Bank Name</label>
              <input type="text" id="platformBankName" placeholder="Enter your bank name" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Platform IBAN</label>
              <input type="text" id="platformBankIban" placeholder="Enter your IBAN" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
            </div>
          </div>

          <!-- PayPal Platform -->
          <div id="platformPaypal" style="display: none;">
            <div style="background: #fef3c7; border: 1px solid #fcd34d; border-radius: 8px; padding: 12px; margin-bottom: 16px;">
              <p style="margin: 0; font-size: 12px; color: #d97706; font-weight: 500;">⚠️ PayPal is not yet fully automated. You will need to manually complete the transfer through PayPal.</p>
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Platform PayPal Email</label>
              <input type="email" id="platformPaypalEmail" placeholder="platform@example.com" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Recipient PayPal Email</label>
              <input type="email" id="recipientPaypalEmail" placeholder="user@example.com" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box; background: #f9fafb;">
            </div>
          </div>

          <!-- PalPay Platform -->
          <div id="platformPalpay" style="display: none;">
            <div style="background: #fef3c7; border: 1px solid #fcd34d; border-radius: 8px; padding: 12px; margin-bottom: 16px;">
              <p style="margin: 0; font-size: 12px; color: #d97706; font-weight: 500;">⚠️ PalPay is not yet fully automated. You will need to manually complete the transfer through PalPay.</p>
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Platform PalPay Mobile Number</label>
              <input type="text" id="platformPalpayMobile" placeholder="Enter your mobile number" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box;">
            </div>
            <div class="input-group" style="margin-bottom: 16px;">
              <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Recipient PalPay Mobile Number</label>
              <input type="text" id="recipientPalpayMobile" placeholder="User's mobile number" 
                style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box; background: #f9fafb;">
            </div>
          </div>

          <!-- Transfer Note -->
          <div class="input-group" style="margin-bottom: 16px;">
            <label style="display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 6px;">Transfer Note (optional)</label>
            <textarea id="transferNote" rows="2" placeholder="Internal note for this transfer..." 
              style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; box-sizing: border-box; resize: vertical;"></textarea>
          </div>
        </div>

        <!-- Error Message -->
        <div id="transferError" style="display: none; background: #fee2e2; border: 1px solid #fecaca; border-radius: 6px; padding: 12px; margin-top: 16px; color: #dc2626; font-size: 13px;"></div>
        
        <!-- Success Message -->
        <div id="transferSuccess" style="display: none; background: #d1fae5; border: 1px solid #a7f3d0; border-radius: 6px; padding: 12px; margin-top: 16px; color: #059669; font-size: 13px;"></div>
      </div>

      <!-- Footer -->
      <div class="modal-footer" style="padding: 16px 24px; border-top: 1px solid #e5e7eb; display: flex; justify-content: flex-end; gap: 12px;">
        <button id="transferCancelBtn" onclick="closeTransferModal()" style="padding: 10px 20px; border: 1px solid #d1d5db; background: #fff; color: #374151; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 500;">Cancel</button>
        <button id="transferBackBtn" onclick="transferGoToStep(1)" style="display: none; padding: 10px 20px; border: 1px solid #d1d5db; background: #fff; color: #374151; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 500;">Back</button>
        <button id="transferNextBtn" onclick="transferGoToStep(2)" style="padding: 10px 24px; background: #ff9a17; color: #fff; border: none; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600;">Next</button>
        <button id="transferExecuteBtn" onclick="executeTransferFromModal()" style="display: none; padding: 10px 24px; background: #059669; color: #fff; border: none; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 600;">
          <span id="transferExecuteText">Execute Transfer</span>
          <span id="transferExecuteLoading" style="display: none;">Processing...</span>
        </button>
      </div>
    </div>
  </div>
</body>
