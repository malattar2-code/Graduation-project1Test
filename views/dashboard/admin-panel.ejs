                          <th>User Id</th>
                          <th>User email</th>
                          <th>User fullName</th>
                          <th>Status</th>
                          <th>Created At</th>
                          <th class="th-btn">Resolved</th>
                          <th class="th-btn">Delete</th>
                      </tr>
                  </thead>
                  <tbody id="complaintsTableBody">
                      <% if (allComplaints && allComplaints.length > 0) { %>
                          <% console.log('Rendering complaints in template, count:', allComplaints.length); %>
                          <% allComplaints.forEach(function(complaint, index) { %>
                              <% console.log('Rendering complaint:', complaint.complaint_id, complaint.status); %>
                              <tr id="complaint-<%= complaint.complaint_id %>">
                                  <td><%= complaint.complaint_id %></td>
                                  <td class="complaint-content">
                                      <div class="content-preview">
                                          <%= complaint.complaint_content && complaint.complaint_content.length > 100 ? 
                                              complaint.complaint_content.substring(0, 100) + '...' : 
                                              (complaint.complaint_content || 'No content') %>
                                      </div>
                                      <% if (complaint.complaint_content && complaint.complaint_content.length > 100) { %>
                                          <button class="view-more-btn" onclick="toggleComplaintContent(<%= complaint.complaint_id %>)">View More</button>
                                          <div class="full-content" id="full-content-<%= complaint.complaint_id %>" style="display: none;">
                                              <%= complaint.complaint_content %>
                                          </div>
                                      <% } %>
                                  </td>
                                  <td><%= complaint.user_id %></td>
                                  <td><%= complaint.user_email %></td>
                                  <td><%= complaint.user_full_name %></td>
                                  <td>
                                      <span class="status-badge status-<%= complaint.status %>">
                                          <%= complaint.status %>
                                      </span>
                                  </td>
                                  <td><%= complaint.created_at ? new Date(complaint.created_at).toLocaleDateString() : 'N/A' %></td>
                                  <td class="td-btn">
                                      <% if (complaint.status !== 'resolved') { %>
                                          <button class="resolve-btn" onclick="resolveComplaint(<%= complaint.complaint_id %>)">
                                              Resolve
                                          </button>
                                      <% } else { %>
                                          <span class="resolved-text">Resolved</span>
                                      <% } %>
                                  </td>
                                  <td class="td-btn">
                                      <button class="delete-btn" onclick="deleteComplaint(<%= complaint.complaint_id %>)">
                                          Delete
                                      </button>
                                  </td>
                              </tr>
                          <% }); %>
                      <% } else { %>
                          <% console.log('No complaints to render in template'); %>
                          <tr>
                              <td colspan="9" class="no-data">No complaints found</td>
                          </tr>
                      <% } %>
                  </tbody>
              </table>
          </div>
