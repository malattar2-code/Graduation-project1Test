        <!-- Start Table Search Filter -->
        <div class="table-search-filter">
          <div class="filter-menu">
            <form id="usersFilterForm">
              <div class="filter-header">
                <div class="filter-title">Users Table Filter</div>
                <div class="filter-actions">
                  <button class="apply-btn btn-website" type="submit">Apply Filters</button>
                  <a class="reset-btn btn-website" href="" onclick="resetUsersFilter(event)">Reset</a>
                </div>
              </div>

              <div class="horizontal-filters">
                <div class="filter-group">
                  <div class="filter-category" onclick="toggleFilter(this)">
                    <span>User Type</span>
                    <span class="arrow">▼</span>
                  </div>
                  <div class="filter-options">
                    <div class="filter-option"><label><input type="checkbox" name="user_type[]" value="requester">Requester</label></div>
                    <div class="filter-option"><label><input type="checkbox" name="user_type[]" value="donor">Donor</label></div>
                    <div class="filter-option"><label><input type="checkbox" name="user_type[]" value="Charity">Charity</label></div>
                  </div>
                </div>

                <div class="filter-group">
                  <div class="filter-category" onclick="toggleFilter(this)">
                    <span>Status</span>
                    <span class="arrow">▼</span>
                  </div>
                  <div class="filter-options">
                    <div class="filter-option"><label><input type="checkbox" name="status[]" value="verified">Verified</label></div>
                    <div class="filter-option"><label><input type="checkbox" name="status[]" value="unverified">Unverified</label></div>
                    <div class="filter-option"><label><input type="checkbox" name="status[]" value="banned">Banned</label></div>
                    <div class="filter-option"><label><input type="checkbox" name="status[]" value="active">Active</label></div>
                  </div>
                </div>

                <div class="filter-group">
                  <div class="filter-category" onclick="toggleFilter(this)">
                    <span>Search</span>
                    <span class="arrow">▼</span>
                  </div>
                  <div class="filter-options">
                    <div class="filter-option">
                      <input type="text" name="search" placeholder="Name or Email..." style="padding: 8px; border: 1px solid #ddd; border-radius: 4px; width: 100%;">
                    </div>
                  </div>
                </div>
              </div>
            </form>
          </div>
        </div>
        <!-- End Filter -->
