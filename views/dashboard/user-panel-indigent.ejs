                  </div>
                  <div class="birthday-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-calendar3" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationEstablishmentDateTgt">Establishment Date :</h1>
                    <h2><%= safeUser.charity_establishment_date ? new Date(safeUser.charity_establishment_date).toLocaleDateString('en-US') : 'Not provided' %></h2>
                  </div>
                <% } else { %>
                  <div class="name-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-hash" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationNameTitleTgt">Name :</h1>
                    <h2><%= safeUser.name || safeUser.full_name || 'Not provided' %></h2>
                  </div>
                  <div class="birthday-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-cake2" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationBirthDayTitleTgt">BirthDay :</h1>
                    <h2><%= safeUser.birth_date || 'Not provided' %></h2>
                  </div>
                <% } %>
              </div>

              <div class="flex-boxes">
                <% if (isCharity) { %>
                  <div class="gender-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-card-text" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationDescriptionTgt">Description :</h1>
                    <h2 style="font-size:13px;line-height:1.4;"><%= safeUser.charity_description || 'Not provided' %></h2>
                  </div>
                  <div class="whatsapp-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-whatsapp" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationWhatsAppNumberTitleTgt">WhatsApp Number :</h1>
                    <h2><%= userPhone %></h2>
                  </div>
                <% } else { %>
                  <div class="gender-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-gender-male" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationGenderTitleTgt">Gender :</h1>
                    <%
                      var gVal = safeUser.gender || '';
                      var userGender = gVal ? (gVal.charAt(0).toUpperCase() + gVal.slice(1).toLowerCase()) : 'Not provided';
                    %>
                    <h2><%= userGender %></h2>
                  </div>
                  <div class="whatsapp-box info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-whatsapp" viewBox="0 0 16 16">...</svg>
                    <h1 class="sub-title" data-i18n="userPanelAccountInformationWhatsAppNumberTitleTgt">WhatsApp Number :</h1>
                    <h2><%= userPhone %></h2>
                  </div>
                <% } %>
              </div>

              <div class="flex-boxes">
                <div class="address-box info-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-geo-alt" viewBox="0 0 16 16">...</svg>
                  <h1 class="sub-title" data-i18n="userPanelAccountInformationAddressTitleTgt">Address :</h1>
                  <h2><%= typeof userLocation !== 'undefined' ? userLocation : 'Not provided' %></h2>
                </div>
                <div class="email-box info-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-envelope" viewBox="0 0 16 16">...</svg>
                  <h1 class="sub-title" data-i18n="userPanelAccountInformationEmailTitleTgt">Email :</h1>
                  <h2><%= userEmail %></h2>
                </div>
              </div>
            </div>

            <div class="split-line-large"></div>
            <form class="change-settings" id="changeSettingsForm">
              <div class="flex-boxes">
                <div class="box-one">
                  <!-- Old Password -->
                  <div class="input-box old-password">
                    <label class="label" for="oldPassword" data-i18n="userPanelAccountChangePasswordLabelTgt">Old Password</label>
                    <input type="password" id="oldPassword" name="oldPassword" maxlength="128">
                    <div class="validation-error" id="old-password-error" style="display: none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                      </svg>
                      <p class="error-message"></p>
                    </div>
                  </div>

                  <!-- New Password -->
                  <div class="input-box new-password">
                    <label class="label" for="newPassword" data-i18n="userPanelAccountChangeNewPasswordLabelTgt">New Password</label>
                    <input type="password" id="newPassword" name="newPassword" maxlength="128">
                    <div class="validation-error" id="new-password-error" style="display: none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                      </svg>
                      <p class="error-message"></p>
                    </div>
                  </div>

                  <!-- Confirm New Password -->
                  <div class="input-box confirm-new-password">
                    <label class="label" for="confirmNewPassword" data-i18n="userPanelAccountChangeConfirmNewPasswordLabelTgt">Confirm New Password</label>
                    <input type="password" id="confirmNewPassword" name="confirmNewPassword" maxlength="128">
                    <div class="validation-error" id="confirm-new-password-error" style="display: none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                      </svg>
                      <p class="error-message"></p>
                    </div>
                  </div>
                </div>
                <div class="box-two">
                  <!-- CHANGE-USER-IMAGE-BOX: Styled with user icon -->
                  <div class="change-user-image-box">
                    <div class="image-upload-wrapper">
                      <div class="upload-area" id="userImageUploadArea">
                        <input type="file" name="image" id="changeUserImage" class="image-input" accept="image/*">
                        <div class="upload-placeholder">
                          <i class="fa fa-user-circle" aria-hidden="true"></i>
                          <span class="upload-text" data-i18n="userPanelAccountChangeImageLabelTgt">Change Your Image</span>
                        </div>
                        <div class="upload-preview" id="userImagePreview" style="display: none;">
                          <img src="" alt="Preview" id="userImagePreviewImg">
                          <button type="button" class="remove-image-btn" id="removeUserImage">
                            <i class="fa fa-times"></i>
                          </button>
                        </div>
                      </div>
                      <div class="validation-error" id="change-user-image-error" style="display: none;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-circle" viewBox="0 0 16 16">
                          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                          <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                        </svg>
                        <p class="error-message"></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Submit Button -->
              <div class="change-btn-box">
                <button type="submit" class="change-btn btn-website" data-i18n="userPanelAccountChangeBtnTgt">Save Changes</button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </div>
  </header>

  <footer class="footer-sec user-panel-footer">
    <div class="copyright-box">
      <ul class="copyright-box-list">
        <li><a href="#">Terms &amp; Conditions</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li>&copy; 2025 Copyright Nowrap Inc.</li>
      </ul>
    </div>
  </footer>

  <!-- Data bridge for categories (remains as the only inline data source) -->
  <div id="categories-data" data-categories='<%= JSON.stringify(categories || []) %>' style="display:none;"></div>
  
  <!-- External libraries -->
  <script src="/assets/js/jquery.js"></script>
  <script src="/assets/js/owl.carousel.min.js"></script>
  <script src="/assets/libs/i18next.min.js"></script>
  <script src="/assets/libs/i18nextHttpBackend.js"></script>
  <script src="/assets/libs/i18nextBrowserLanguageDetector.js"></script>
  <script src="https://www.gstatic.com/charts/loader.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@yaireo/tagify"></script>
  <script src="https://cdn.jsdelivr.net/npm/fuse.js/dist/fuse.min.js"></script>
  <script src="/assets/js/google-translate-custom.js"></script>
  <script src="/assets/js/notifications.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <!-- Consolidated application logic -->
  <script>
    window.appConfig = {
      userType: '<%= user && user.user_type ? user.user_type : "requester" %>'
    };
    </script>
  <script src="/assets/js/user-panel.js"></script>
  <script>
    window.STRIPE_PUBLIC_KEY = '<%= process.env.STRIPE_PUBLISHABLE_KEY %>';
  </script>
  <%- include('../withdrawal-modal') %>
  <script src="/assets/js/withdrawal-modal.js"></script>
</body>
</html>
