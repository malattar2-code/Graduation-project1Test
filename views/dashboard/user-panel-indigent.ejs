            <div class="my-fundraisers-boxes">
              <% if (fundraisers && fundraisers.length > 0) { %>
                <% fundraisers.forEach(function(fundraiser) { %>
                  <%
                    var isCharity   = user && (user.user_type === 'Charity');
                    var fType       = fundraiser.fundraiser_type || 'Fundraiser';
                    var fStatus     = fundraiser.fundraiser_status;
                  %>
                  <div class="fundraiser-box" data-id="<%= fundraiser.public_id %>">
                    
                    <!-- Dynamic routing based on status — handled via JS event delegation -->
                    <% if (fStatus === 'waiting_verification') { %>
                      <div class="fundraiser-img fundraiser-img-disabled" 
                          style="background: url('<%= fundraiser.fundraiser_main_image %>') center/cover; opacity: 0.6; cursor: not-allowed; position: relative;"
                          title="Campaign under verification - donations not yet active">
                        <div class="verification-overlay" style="position: absolute; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; border-radius: inherit;">
                          <span style="color: #fff; font-size: 14px; font-weight: 600; padding: 8px 16px; background: rgba(255,154,23,0.9); border-radius: 6px; display: flex; align-items: center; gap: 5px;">
                            <i class="fa fa-clock-o" style="margin-right: 6px;"></i>
                            <span>Awaiting Verification</span> 
                          </span>
                        </div>
                      </div>
                    <% } else { %>
                      <div class="fundraiser-img js-fundraiser-img" 
                          style="background: url('<%= fundraiser.fundraiser_main_image %>') center/cover;"
                          data-status="<%= fStatus %>"
                          data-id="<%= fundraiser.public_id %>">
                      </div>
                    <% } %>

                    <div class="fundraiser-title">
                      <h2 class="main-title">
                        <%= fundraiser.fundraiser_title.length > 15 ?
                          fundraiser.fundraiser_title.substring(0, 15) + '...' :
                          fundraiser.fundraiser_title %></h2>
                      <span class="user-location"><%= typeof userLocation !== 'undefined' ? userLocation : 'Location not specified' %></span>
                    </div>

                    <% if (isCharity) { %>
                      <div class="status-and-type-box">
                        <span class="status-badge <%= fStatus %>"><%= fStatus.replace(/_/g, ' ') %></span>
                        <small>[<%= fType %>]</small>
                      </div>
                    <% } %>

                    <% if (fundraiser.fundraiser_categories && fundraiser.fundraiser_categories.length > 0) { %>
                      <div class="fundraiser-categories">
                        <% fundraiser.fundraiser_categories.forEach(function(cat, idx) { %><span class="category-tag"><%= cat %></span><% }); %>
                      </div>
                    <% } %>

                    <p class="fundraiser-des">
                      <%= fundraiser.fundraiser_description.length > 100 ?
                          fundraiser.fundraiser_description.substring(0, 100) + '...' :
                          fundraiser.fundraiser_description %>
                    </p>

                    <div class="fundraiser-btns">
                      
                      <% if (fType === 'Fundraiser' && fStatus === 'incompleted' && fundraiser.fundraiser_target_amount) { %>
                        <div class="donation-bar">
                          <div class="donation-scale">
                            <div class="donation-progress" style="width: <%= fundraiser.progressWidth %>"></div>
                          </div>
                          <div class="donation-money-number">
                            <div class="money target-amount">
                              $<%= Math.round(fundraiser.fundraiser_collected_amount) %> / $<%= Math.round(fundraiser.fundraiser_target_amount) %>
                            </div>
                          </div>
                        </div>
                      <% } %>

                      <div class="flex-btns">
                        <%
                          var collected = parseFloat(fundraiser.fundraiser_collected_amount) || 0;
                          var target = parseFloat(fundraiser.fundraiser_target_amount) || 0;
                          var pctReached = target > 0 ? (collected / target) * 100 : 0;
                          
                          // Check if early withdrawal was already used (from DB flag or completed requests)
                          var earlyWithdrawalUsed = fundraiser.early_withdrawal_used === true || 
                                                    fundraiser.early_withdrawal_used === 'true' || 
                                                    fundraiser.early_withdrawal_used === 1;
                          
                          // For final withdrawal eligibility: completed/expired status with funds remaining
                          var canWithdrawFinal = ['completed', 'expired'].includes(fStatus) && collected > 0;
                          
                          // Early withdrawal: only if NOT used, campaign is urgent, incomplete, and 40%+ reached
                          var canWithdrawEarly = !earlyWithdrawalUsed &&
                                                  fundraiser.allow_early_withdrawal === true &&
                                                  fStatus === 'incompleted' && 
                                                  target > 0 && 
                                                  pctReached >= 40;
                        %>

                        <% if (canWithdrawEarly) { %>
                          <!-- Early Withdrawal Button: One-time, 40%+ reached, status incomplete -->
                          <button class="withdraw-btn btn-website" 
                                  data-fundraiser-id="<%= fundraiser.public_id %>"
                                  data-campaign-status="<%= fundraiser.fundraiser_status %>"
                                  data-is-urgent="<%= fundraiser.is_urgent %>"
                                  data-withdrawal-type="early">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                              <polyline points="17 6 23 6 23 12"></polyline>
                            </svg>
                            Withdraw Funds (Early)
                          </button>
                        <% } %>

                        <% if (canWithdrawFinal) { %>
                          <!-- Final Withdrawal Button: Campaign completed/expired, withdraw ALL remaining funds -->
                          <button class="receive-btn btn-website" 
                                  data-fundraiser-id="<%= fundraiser.public_id %>"
                                  data-campaign-status="<%= fStatus %>"
                                  data-withdrawal-type="final"
                                  style="background-color: #4BB543;">
                            Withdraw All Funds
                          </button>
                        <% } %>

                        <% if (!isCharity) { %>
                          <!-- Requester view: non-withdrawal buttons -->
                          <% if (fStatus === 'transferred') { %>
                            <span style="padding:10px 20px;background:#6c757d;color:#fff;border-radius:5px;display:inline-block;" data-i18n="userPanelMyFundraisersReceiveDoneBtnTgt">✅ Done</span>
                            <button class="delete-btn btn-website" data-fundraiser-id="<%= fundraiser.public_id %>" style="margin-left:10px;" data-i18n="userPanelMyFundraisersDeleteBtnTgt">Delete</button>
                          <% } else if (fStatus === 'incompleted' && !canWithdrawEarly) { %>
                            <button class="delete-btn btn-website" data-fundraiser-id="<%= fundraiser.public_id %>" data-i18n="userPanelMyFundraisersDeleteBtnTgt">Delete</button>
                          <% } else if (fStatus === 'waiting_verification') { %>
                            <button class="verify-campaign-btn btn-website"
                                    data-fundraiser-id="<%= fundraiser.public_id %>"
                                    data-user-type="requester"
                                    style="padding:8px 16px;background:#ff9a17;color:#fff;border-radius:5px;border:none;cursor:pointer;font-weight:600;" data-i18n="userPanelMyFundraisersVerifyCampaignBtnTgt">Verify Campaign
                            </button>
                            <span class="verification-pending-msg" 
                                  id="verifyMsg-<%= fundraiser.public_id %>" 
                                  style="display:none;padding:8px 16px;background:#e8f5e8;color:#2e7d32;border-radius:5px;font-size:13px;font-weight:500;">
                              <i class="fa fa-clock-o" style="margin-right:5px;"></i>
                              <span>Interview notification will be sent within 24 hours.</span>
                            </span>
                          <% } %>
                        <% } else { %>
                          <!-- Charity view: non-withdrawal buttons -->
                          <% if (fStatus === 'waiting_verification') { %>
                            <button class="verify-campaign-btn btn-website"
                                    data-fundraiser-id="<%= fundraiser.public_id %>"
                                    data-user-type="<%= isCharity ? 'Charity' : 'requester' %>"
                                    style="padding:8px 16px;background:#ff9a17;color:#fff;border-radius:5px;border:none;cursor:pointer;font-weight:600;">
                              <i class="fa fa-check-circle" style="margin-right:5px;"></i> Verify Campaign
                            </button>
                            <span class="verification-pending-msg" 
                                  id="verifyMsg-<%= fundraiser.public_id %>" 
                                  style="display:none;padding:8px 16px;background:#e8f5e8;color:#2e7d32;border-radius:5px;font-size:13px;font-weight:500;">
                              <i class="fa fa-clock-o" style="margin-right:5px;"></i> Interview notification will be sent within 24 hours.
                            </span>
                          <% } %>
                          
                          <% if (fType === 'Fundraiser') { %>
                            <% if (fStatus === 'incompleted' && !canWithdrawEarly) { %>
                              <button class="delete-btn btn-website" data-fundraiser-id="<%= fundraiser.public_id %>" data-i18n="userPanelMyFundraisersDeleteBtnTgt">Delete</button>
                            <% } else if (fStatus === 'create_form') { %>
                              <a href="/fundraiser-form/<%= fundraiser.public_id %>" class="btn-website" style="padding:8px 16px;background:#0a58ca;color:#fff;border-radius:5px;text-decoration:none;" data-i18n="userPanelMyFundraisersAddFormBtnTgt">Add Form</a>
                            <% } else if (fStatus === 'Waiting_requesters') { %>
                              <a href="/fundraiser-requesters/<%= fundraiser.public_id %>" class="btn-website waiting-btn" style="padding:8px 16px;background:#6f42c1;color:#fff;border-radius:5px;text-decoration:none;" data-i18n="userPanelMyFundraisersWaitingBtnTgt">Waiting...</a>
                            <% } else if (fStatus === 'transferred') { %>
                              <span style="padding:10px 20px;background:#6c757d;color:#fff;border-radius:5px;display:inline-block;" data-i18n="userPanelMyFundraisersReceiveDoneBtnTgt">✅ Done</span>
                              <button class="delete-btn btn-website" data-fundraiser-id="<%= fundraiser.public_id %>" style="margin-left:10px;" data-i18n="userPanelMyFundraisersDeleteBtnTgt">Delete</button>
                            <% } %>
                          <% } else if (fType === 'Donation') { %>
                            <% if (fStatus === 'create_form') { %>
                              <a href="/fundraiser-form/<%= fundraiser.public_id %>" class="btn-website" style="background:#0a58ca;" data-i18n="userPanelMyFundraisersAddFormBtnTgt">Add Form</a>
                            <% } else if (fStatus === 'Waiting_requesters') { %>
                              <a href="/fundraiser-requesters/<%= fundraiser.public_id %>" class="btn-website waiting-btn" style="padding:8px 16px;background:#6f42c1;color:#fff;border-radius:5px;text-decoration:none;" data-i18n="userPanelMyFundraisersWaitingBtnTgt">Waiting...</a>
                            <% } else if (fStatus === 'transferred') { %>
                              <span style="padding:10px 20px;background:#6c757d;color:#fff;border-radius:5px;display:inline-block;" data-i18n="userPanelMyFundraisersReceiveDoneBtnTgt">✅ Done</span>
                            <% } %>
                          <% } %>
                        <% } %>

                        <%
                          var hasStripe = false;
                          if (fundraiser.hasStripeAccount === true) hasStripe = true;
                          else if (fundraiser.stripeAccountId && String(fundraiser.stripeAccountId).length > 0) hasStripe = true;
                        %>
                        <% if (fundraiser.hasCompletedEarlyTransfer && !fundraiser.hasMilestoneAchievement) { %>
                          <button class="create-achievement-btn btn-website"
                                  data-fundraiser-id="<%= fundraiser.public_id %>"
                                  data-achievement-type="milestone"
                                  data-i18n="userPanelCreateMilestoneBtnTgt">
                            <i class="fa fa-trophy"></i> Create Campaign Milestone
                          </button>
                        <% } %>

                        <% if (fundraiser.hasCompletedFinalTransfer && !fundraiser.hasFinalAchievement) { %>
                          <button class="create-achievement-btn btn-website"
                                  data-fundraiser-id="<%= fundraiser.public_id %>"
                                  data-achievement-type="final"
                                  data-i18n="userPanelCreateFinalAchievementBtnTgt">
                            <i class="fa fa-flag-checkered"></i> Create Final Achievement
                          </button>
                        <% } %>

                        <% if (hasStripe) { %>
                          <button class="stripe-btn btn-website"
                                  data-fundraiser-id="<%= fundraiser.public_id %>"
                                  style="padding:10px 20px;background:#635BFF;color:#fff;border-radius:5px;border:none;cursor:pointer;">
                            <i class="fa fa-credit-card" style="margin-right:5px;"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="empty-fundraisers-state">
                  <h3 data-i18n="userPanelNoFundraisersTitle">No Fundraisers Yet</h3>
                  <p data-i18n="userPanelNoFundraisersDesc">You haven't created any fundraisers yet.</p>
                </div>
              <% } %>
            </div>
          </div>
 
